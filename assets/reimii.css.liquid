  }

  .article-comment {
    padding: 1rem;
    border-radius: 16px;
  }

  .article-comment-header {
    align-items: flex-start;
    flex-direction: column;
    gap: 0.2rem;
  }

  .article-comment-author {
    font-size: 0.9rem;
  }

  .article-comment-content {
    font-size: 0.9rem;
