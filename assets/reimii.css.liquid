/* =========================================================
   MOBILE
========================================================= */

@media (max-width: 480px) {
  .template-article {
    padding: 2rem 1rem 3rem;
  }

  .article-title {
    font-size: clamp(1.75rem, 9vw, 2.2rem);
    line-height: 1.08;
  }

  .article-meta {
    gap: 0.25rem;
    margin-bottom: 1.25rem;
  }

  .article-author,
  .article-date {
    font-size: 0.82rem;
  }

  .article-image {
    max-height: 360px;
    margin-bottom: 1.5rem;
