@font-face {
  font-family: "Reimii Display";
  src: url("{{ 'ReimiiDisplay.ttf' | asset_url }}") format("truetype");
}

@font-face {
  font-family: "Reimii Sans";
  src: url("{{ 'ReimiiSans.ttf' | asset_url }}") format("truetype");
}

:root {
  /* Fonts */
  --r-font-heading:
    "Reimii Display", "Arial Rounded MT Bold", "Trebuchet MS", sans-serif;

  --r-font-body:
    "Reimii Sans", Inter, ui-sans-serif, system-ui, -apple-system,
    BlinkMacSystemFont, "Segoe UI", sans-serif;

  /* Backgrounds */
  --r-bg: #fcfbff;
  --r-bg-alt: #fff7fc;

  /* Neutrals */
  --r-white: #fffbff;
  --r-black: #241f35;

  /* Surfaces */
  --r-surface: var(--r-white);
  --r-surface-soft: var(--r-cream);
  --r-surface-pink: #fff1f8;
  --r-surface-purple: #f3edff;

  /* Typography */
  --r-text: #312c43;
  --r-text-strong: #241f35;
  --r-muted: #756f88;
  --r-muted-dark: #5e5870;

  /* Purple */
  --r-primary: #8e73d8;
  --r-primary-dark: #7457c7;
  --r-primary-soft: #ddd5f3;

  /* Pink */
  --r-pink: #f7a9d4;
  --r-pink-dark: #d96dae;
  --r-pink-soft: #fdd7ec;

  /* Supporting colors */
  --r-cream: #fff9ef;
  --r-warning: #ffe3a3;
  --r-success: #dff8f0;
  --r-info: #e7f0ff;
  --r-disabled: #eceaf2;

  /* Borders */
  --r-border: rgba(49, 44, 67, 0.08);
  --r-border-strong: rgba(49, 44, 67, 0.14);

  /* Shadows */
  --r-shadow: 0 10px 30px rgba(116, 87, 199, 0.1);
  --r-shadow-hover: 0 18px 50px rgba(116, 87, 199, 0.18);
  --r-shadow-strong: 0 24px 90px rgba(49, 44, 67, 0.24);

  /* Gradients */
  --r-gradient-primary: linear-gradient(
    135deg,
    var(--r-pink) 0%,
    var(--r-primary) 100%
  );

  --r-gradient-primary-hover: linear-gradient(
    135deg,
    var(--r-pink-dark) 0%,
    var(--r-primary-dark) 100%
  );

  --r-gradient-soft: linear-gradient(
    135deg,
    var(--r-surface-pink),
    var(--r-surface-purple)
  );

  --r-gradient-card: var(--r-gradient-soft);

  --r-gradient-story: linear-gradient(
    135deg,
    var(--r-primary-soft),
    var(--r-surface-pink)
  );

  /* UI */
  --r-overlay: rgba(49, 44, 67, 0.36);
  --r-header-bg: rgba(252, 251, 255, 0.86);

  /* Radius */
  --r-radius: 24px;
  --r-radius-lg: 34px;
  --r-pill: 999px;

  /* Tailwind variable overrides */
  --font-sans: var(--r-font-body);
  --default-font-family: var(--r-font-body);

  --color-white: var(--r-white);
  --color-gray-500: var(--r-muted);
  --color-gray-900: var(--r-text-strong);
}

/* =========================================================
   GLOBAL BRAND STYLES
========================================================= */

html {
  font-family: var(--r-font-body) !important;
  color: var(--r-text);
  background-color: var(--r-bg);
}

body {
  min-height: 100vh;
  font-family: var(--r-font-body);
  color: var(--r-text);
  background-color: var(--r-bg);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: var(--r-font-heading) !important;
  color: var(--r-text-strong);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.02em;
  text-align: center;
}

a {
  color: inherit;
  transition:
    all 180ms ease,
    opacity 180ms ease;
}

a:hover {
  color: var(--r-primary-dark);
  opacity: 0.9;
}

button,
input,
select,
textarea {
  font-family: inherit;
}

::selection {
  color: var(--r-text-strong);
  background: var(--r-pink-soft);
}

:focus-visible {
  outline: 3px solid color-mix(in srgb, var(--r-primary) 40%, transparent);
  outline-offset: 3px;
}

/* =========================================================
   REIMII TYPOGRAPHY UTILITIES
========================================================= */

.font-reimii {
  font-family: var(--r-font-body);
}

.font-reimii-display {
  font-family: var(--r-font-heading);
}

