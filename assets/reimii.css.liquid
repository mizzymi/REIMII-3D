/* =========================================================
   REIMII COMPONENT HELPERS
========================================================= */

.reimii-card {
  color: var(--r-text);
  background: var(--r-gradient-card);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius);
  box-shadow: var(--r-shadow);
  transition:
    transform 220ms ease,
    box-shadow 220ms ease,
    border-color 220ms ease;
}

.reimii-card:hover {
  transform: translateY(-3px);
  border-color: var(--r-border-strong);
  box-shadow: var(--r-shadow-hover);
}

.reimii-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  min-height: 44px;
  padding: 0.75rem 1.4rem;
  font-family: var(--r-font-body);
  font-weight: 700;
  color: var(--r-white);
  background: var(--r-gradient-primary);
  border: 0;
  border-radius: var(--r-pill);
  box-shadow: 0 8px 22px rgba(116, 87, 199, 0.18);
  cursor: pointer;
  transition:
    transform 180ms ease,
    box-shadow 180ms ease,
    background 180ms ease;
}

.reimii-button:hover {
  color: var(--r-white);
  background: var(--r-gradient-primary-hover);
  box-shadow: var(--r-shadow-hover);
  transform: translateY(-2px);
}

.reimii-button:active {
  transform: translateY(0);
}

.reimii-button-secondary {
  color: var(--r-primary-dark);
  background: var(--r-surface);
  border: 1px solid var(--r-primary-soft);
  box-shadow: none;
}

.reimii-button-secondary:hover {
  color: var(--r-primary-dark);
  background: var(--r-surface-purple);
  border-color: var(--r-primary);
  box-shadow: var(--r-shadow);
}

.reimii-input {
  width: 100%;
  min-height: 46px;
  padding: 0.75rem 1rem;
  color: var(--r-text);
  background-color: var(--r-surface);
  border: 1px solid var(--r-border-strong);
  border-radius: 16px;
  transition:
    border-color 180ms ease,
    box-shadow 180ms ease;
}

.reimii-input::placeholder {
  color: var(--r-muted);
}

.reimii-input:focus {
  border-color: var(--r-primary);
  outline: none;
  box-shadow: 0 0 0 4px rgba(142, 115, 216, 0.14);
}

.icon {
  width: 24px;
  height: 24px;
}

.logo {
  height: 24px;
  width: auto;
}
