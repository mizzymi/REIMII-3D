  }

  .article-content p {
    margin-bottom: 1.25rem;
  }

  .article-content ul,
  .article-content ol {
    padding-left: 1.25rem;
  }

  .article-content blockquote {
    margin: 1.5rem 0;
    padding: 1rem;
    border-radius: 14px;
  }

  .article-content pre {
    margin: 1.5rem -0.25rem;
    padding: 1rem;
    border-radius: 14px;
  }

  .article-content iframe,
  .article-content video {
    margin: 1.5rem 0;
    border-radius: 14px;
  }

  .article-comments {
    margin-top: 2.5rem;
    padding-top: 1.75rem;
  }

  .article-comments-title {
    margin-bottom: 1.5rem;
    font-size: 1.75rem;
  }

  .article-comments-list {
