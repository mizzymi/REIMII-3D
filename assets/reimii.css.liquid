/* =========================================================
   COLLECTION TEMPLATE
========================================================= */

.collection-container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 4rem 1.5rem;
}

.collection-header {
  max-width: 760px;
  margin: 0 auto 3rem;
  padding: 2rem;
  text-align: center;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius);
}

.collection-title {
  margin-bottom: 0.75rem;
  font-size: clamp(2.2rem, 5vw, 3.5rem);
}

.collection-description {
  color: var(--r-muted-dark);
  line-height: 1.7;
}

.collection-count {
  display: inline-flex;
  margin-top: 1.25rem;
  padding: 0.45rem 0.9rem;
  background: var(--r-surface);
  border: 1px solid var(--r-border);
  border-radius: var(--r-pill);
  font-size: 0.85rem;
  font-weight: 600;
}

.collection-heading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1.25rem;
}

.collection-image {
  display: block;
  width: 150px;
  height: 150px;
  flex-shrink: 0;
  object-fit: cover;
  border-radius: 22px;
  box-shadow: var(--r-shadow);
}

.collection-heading .collection-title {
  margin: 0;
  text-align: left;
}

/* =========================================================
   COLLECTION GRID
========================================================= */

.collection-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 2rem;
  padding: 0 0.75rem;
}

.collection-product {
  position: relative;
  overflow: hidden;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius);
  transition:
    transform 280ms cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 280ms ease,
    border-color 280ms ease,
    background 280ms ease;
}

.collection-product::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.18),
    rgba(255, 255, 255, 0)
  );
  opacity: 0;
  pointer-events: none;
  transition: opacity 280ms ease;
}

.collection-product:hover {
  transform: translateY(-6px) scale(1.015);
  border-color: var(--r-primary);
  box-shadow: var(--r-shadow-hover);
  background: linear-gradient(135deg, #ffffff 0%, var(--r-surface-purple) 100%);
}

.collection-product:hover::before {
  opacity: 1;
}

.collection-product:hover .collection-product-title {
  color: var(--r-primary-dark);
}

.collection-product:hover .collection-product-current-price {
  color: var(--r-primary);
}

.collection-product:hover .collection-product-image {
  transform: scale(1.06);
}

.collection-product-link {
  display: flex;
  flex-direction: column;
  height: 100%;
  color: inherit;
}

.collection-product-link:hover {
  opacity: 1;
  color: inherit;
}
/* =========================================================
   PRODUCT IMAGE
========================================================= */

.collection-product-media {
  aspect-ratio: 1;
  overflow: hidden;
  background: var(--r-bg-alt);
}

.collection-product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition:
    transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    filter 0.35s ease;
}

.collection-product:hover .collection-product-image {
  transform: scale(1.06);
  filter: brightness(1.04) saturate(1.05);
}

/* =========================================================
   PRODUCT CONTENT
========================================================= */

.collection-product-content {
  display: flex;
  flex: 1;
  flex-direction: column;
  padding: 1.2rem;
  text-align: left;
}

.collection-product-vendor {
  margin-bottom: 0.3rem;
  color: var(--r-muted);
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.collection-product-title {
  margin-bottom: 0.7rem;
  font-family: var(--r-font-heading);
  font-size: 1.05rem;
  line-height: 1.3;
  text-align: left;
}

.collection-product-price {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: auto;
}

.collection-product-current-price {
  color: var(--r-primary-dark);
  font-weight: 700;
  font-size: 1rem;
}

.collection-product-compare-price {
  color: var(--r-muted);
  text-decoration: line-through;
}
/* =========================================================
   BADGES
========================================================= */

.collection-product-badge {
  top: 0.75rem;
  left: 0.75rem;
  padding: 0.35rem 0.75rem;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  box-shadow: none;
}

.collection-product-badge-sale {
  background: var(--r-gradient-primary);
  color: var(--r-white);
}

.collection-product-badge-sold-out {
  background: var(--r-disabled);
  color: var(--r-text);
}

/* =========================================================
   COLLECTION TABLET
========================================================= */

@media (max-width: 1024px) {
  .collection-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }
}

@media (max-width: 768px) {
  .collection-container {
    padding: 2.75rem 1.25rem;
  }

  .collection-header {
    margin-bottom: 2rem;
    padding: 1.75rem;
  }

  .collection-title {
    font-size: clamp(2rem, 7vw, 2.8rem);
  }

  .collection-description {
    font-size: 0.95rem;
  }

  .collection-grid {
    gap: 1.25rem;
  }

  .collection-product-content {
    padding: 1rem;
  }

  .collection-product-title {
    font-size: 0.95rem;
  }

  .collection-product-current-price {
    font-size: 0.95rem;
  }

  .collection-product-badge {
    top: 0.6rem;
    left: 0.6rem;
    padding: 0.3rem 0.65rem;
    font-size: 0.65rem;
  }

  .collection-heading {
    gap: 1rem;
  }

  .collection-image {
    width: 112px;
    height: 112px;
    border-radius: 18px;
  }

  .collection-heading .collection-title {
    font-size: clamp(1.8rem, 7vw, 2.6rem);
  }
}

/* =========================================================
   COLLECTION MOBILE
========================================================= */

@media (max-width: 480px) {
  .collection-container {
    padding: 2rem 0.75rem 3rem;
  }

  .collection-header {
    padding: 1.5rem 1rem;
    margin-bottom: 1.5rem;
    border-radius: 20px;
  }

  .collection-title {
    font-size: clamp(1.7rem, 8vw, 2.2rem);
  }

  .collection-description {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .collection-count {
    margin-top: 1rem;
    font-size: 0.75rem;
    padding: 0.35rem 0.7rem;
  }

  .collection-grid {
    gap: 0.9rem;
  }

  .collection-product {
    border-radius: 18px;
  }

  .collection-product-content {
    padding: 0.9rem;
  }

  .collection-product-vendor {
    font-size: 0.62rem;
  }

  .collection-product-title {
    margin-bottom: 0.5rem;
    font-size: 0.88rem;
    line-height: 1.25;
  }

  .collection-product-current-price {
    font-size: 0.9rem;
  }

  .collection-product-compare-price,
  .collection-product-price-prefix {
    font-size: 0.72rem;
  }

  .collection-product-badge {
    top: 0.5rem;
    left: 0.5rem;
    padding: 0.28rem 0.55rem;
    font-size: 0.6rem;
  }

  .collection-heading {
    flex-direction: column;
    gap: 0.85rem;
  }

  .collection-image {
    width: 88px;
    height: 88px;
    border-radius: 16px;
  }

  .collection-heading .collection-title {
    text-align: center;
  }
}

/* =========================================================
   SKELETON
========================================================= */

.skeleton {
  display: block;
  position: relative;
  overflow: hidden;
  background: var(--r-primary-soft);
  border-radius: 999px;
}

.skeleton::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.6),
    transparent
  );
  animation: skeleton-loading 1.4s infinite;
}

.skeleton-text {
  width: 35%;
  height: 0.75rem;
}

.skeleton-title {
  width: 100%;
  height: 1.15rem;
  border-radius: 0.5rem;
}

.skeleton-price {
  width: 5rem;
  height: 1rem;
}

@keyframes skeleton-loading {
  to {
    transform: translateX(100%);
  }
}

/* =========================================================
   HERO
========================================================= */

.section-hero {
  padding: 1.5rem;
}

.hero {
  position: relative;
  isolation: isolate;
  min-height: var(--hero-min-height);
  overflow: hidden;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius-lg);
  box-shadow: var(--r-shadow);
}

.hero-media,
.hero-overlay {
  position: absolute;
  inset: 0;
}

.hero-media {
  z-index: -2;
}

.hero-image,
.hero-placeholder,
.hero-placeholder svg {
  display: block;
  width: 100%;
  height: 100%;
}

.hero-image {
  object-fit: cover;
}

.hero-image-mobile {
  display: none;
}

.hero-placeholder {
  background: var(--r-gradient-story);
}

.hero-overlay {
  z-index: 1;
  background: linear-gradient(
    90deg,
    rgba(36, 31, 53, calc(var(--hero-overlay-opacity) + 0.18)) 0%,
    rgba(36, 31, 53, var(--hero-overlay-opacity)) 48%,
    rgba(36, 31, 53, calc(var(--hero-overlay-opacity) * 0.35)) 100%
  );
}

.hero-inner {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  min-height: var(--hero-min-height);
  padding: clamp(2rem, 6vw, 5rem);
}

.hero-content {
  width: 100%;
  max-width: 650px;
  padding: clamp(1.5rem, 4vw, 2.5rem);
  color: var(--r-white);
  background: rgba(36, 31, 53, 0.28);
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: var(--r-radius);
  box-shadow: var(--r-shadow-strong);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.hero-align-left {
  justify-content: flex-start;
}

.hero-align-center {
  justify-content: center;
  text-align: center;
}

.hero-align-center .hero-content {
  margin: 0 auto;
}

.hero-align-right {
  justify-content: flex-end;
  text-align: right;
}

.hero-eyebrow {
  display: inline-flex;
  margin: 0 0 1rem;
  padding: 0.45rem 0.85rem;
  color: var(--r-text-strong);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--r-pink-soft);
  border-radius: var(--r-pill);
}

.hero-heading {
  margin: 0 0 1rem;
  color: var(--r-white);
  font-size: clamp(2.5rem, 6vw, 5rem);
  line-height: 0.98;
  text-align: inherit;
  text-wrap: balance;
}

.hero-text {
  max-width: 560px;
  color: rgba(255, 251, 255, 0.92);
  font-size: clamp(1rem, 1.6vw, 1.15rem);
  line-height: 1.7;
}

.hero-align-center .hero-text {
  margin-right: auto;
  margin-left: auto;
}

.hero-align-right .hero-text {
  margin-left: auto;
}

.hero-text p {
  margin: 0;
}

.hero-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 1.75rem;
}

.hero-align-center .hero-actions {
  justify-content: center;
}

.hero-align-right .hero-actions {
  justify-content: flex-end;
}

.hero-primary-button,
.hero-secondary-button {
  margin: 0;
}

.hero-secondary-button {
  color: var(--r-white);
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(8px);
}

.hero-secondary-button:hover {
  color: var(--r-text-strong);
  background: var(--r-white);
}

@media (max-width: 768px) {
  .section-hero {
    padding: 1rem;
  }

  .hero,
  .hero-inner {
    min-height: var(--hero-mobile-height);
  }

  .hero {
    border-radius: var(--r-radius);
  }

  .hero-inner {
    align-items: center;
    padding: 1.5rem;
  }

  .hero-image-mobile {
    display: block;
  }

  .hero-image-mobile + .hero-overlay {
    display: block;
  }

  .hero-media:has(.hero-image-mobile) .hero-image-desktop {
    display: none;
  }

  .hero-overlay {
    background: linear-gradient(
      180deg,
      rgba(36, 31, 53, 0.04) 20%,
      rgba(36, 31, 53, calc(var(--hero-overlay-opacity) + 0.3)) 100%
    );
  }

  .hero-content {
    max-width: none;
    padding: 1.5rem;
    text-align: center;
    border-radius: 20px;
  }

  .hero-heading {
    font-size: clamp(2.3rem, 11vw, 3.7rem);
  }

  .hero-text {
    margin-right: auto;
    margin-left: auto;
    font-size: 0.98rem;
  }

  .hero-actions {
    justify-content: center;
  }
}

@media (max-width: 480px) {
  .section-hero {
    padding: 0.75rem;
  }

  .hero-inner {
    padding: 0.75rem;
  }

  .hero-content {
    padding: 1.25rem 1rem;
    background: rgba(36, 31, 53, 0.38);
    backdrop-filter: blur(10px);
  }

  .hero-eyebrow {
    margin-bottom: 0.75rem;
    font-size: 0.68rem;
  }

  .hero-heading {
    margin-bottom: 0.75rem;
    font-size: clamp(2rem, 12vw, 3rem);
  }

  .hero-actions {
    flex-direction: column;
    margin-top: 1.25rem;
  }

  .hero-primary-button,
  .hero-secondary-button {
    width: 100%;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero *,
  .hero *::before,
  .hero *::after {
    scroll-behavior: auto !important;
    transition: none !important;
    animation: none !important;
  }
}

/* =========================================================
   SHOP BENEFITS
========================================================= */

.shop-benefits {
  padding: 5rem 1.5rem;
}

.shop-benefits-container {
  max-width: 1200px;
  margin: 0 auto;
}

.shop-benefits-title {
  margin-bottom: 3rem;
  text-align: center;
}

.shop-benefits-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
}

.shop-benefit {
  padding: 2rem;
  text-align: center;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius);
  transition: 0.25s ease;
}

.shop-benefit:hover {
  transform: translateY(-4px);
  box-shadow: var(--r-shadow);
}

.shop-benefit-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 1rem;
}

.shop-benefit h3 {
  margin-bottom: 0.75rem;
  font-size: 1.2rem;
}

.shop-benefit p {
  color: var(--r-muted-dark);
  line-height: 1.6;
}

@media (max-width: 1024px) {
  .shop-benefits-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 640px) {
  .shop-benefits {
    padding: 3rem 1rem;
  }

  .shop-benefits-grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .shop-benefit {
    padding: 1.5rem;
  }
}

/* =========================================================
   BRAND STORY
========================================================= */

.brand-story {
  padding: 5rem 1.5rem;
}

.brand-story-container {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.brand-story-image {
  width: 100%;
  display: block;
  border-radius: var(--r-radius);
  box-shadow: var(--r-shadow);
}

.brand-story-eyebrow {
  display: inline-block;
  margin-bottom: 0.75rem;
  padding: 0.35rem 0.8rem;
  background: var(--r-pink-soft);
  color: var(--r-primary-dark);
  border-radius: var(--r-pill);
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
}

.brand-story-title {
  margin-bottom: 1rem;
  text-align: left;
}

.brand-story-text {
  margin-bottom: 2rem;
  color: var(--r-muted-dark);
  line-height: 1.8;
}

@media (max-width: 768px) {
  .brand-story {
    padding: 3rem 1rem;
  }

  .brand-story-container {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .brand-story-content {
    text-align: center;
  }

  .brand-story-title {
    text-align: center;
  }
}

/* ========================================================= 
  COLLECTION LIST 
========================================================= */
.collection-list-card .collection-product-content {
  align-items: flex-start;
}
.collection-list-card .collection-product-title {
  margin-bottom: 0.6rem;
}
.collection-list-count {
  position: absolute;
  right: 0.75rem;
  bottom: 0.75rem;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  min-height: 30px;
  padding: 0.4rem 0.75rem;
  color: var(--r-text-strong);
  font-size: 0.7rem;
  font-weight: 700;
  background: rgba(255, 251, 255, 0.88);
  border: 1px solid rgba(255, 255, 255, 0.55);
  border-radius: var(--r-pill);
  box-shadow: var(--r-shadow);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}
.collection-list-description {
  margin-bottom: 1rem;
  color: var(--r-muted-dark);
  font-size: 0.88rem;
  line-height: 1.6;
}
.collection-list-link {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: auto;
  color: var(--r-primary-dark);
  font-size: 0.85rem;
  font-weight: 700;
}
.collection-list-link span {
  transition: transform 180ms ease;
}
.collection-list-card:hover .collection-list-link span {
  transform: translateX(4px);
}
@media (max-width: 480px) {
  .collection-list-count {
    right: 0.5rem;
    bottom: 0.5rem;
    min-height: 24px;
    padding: 0.3rem 0.55rem;
    font-size: 0.6rem;
  }
  .collection-list-description {
    font-size: 0.78rem;
    line-height: 1.5;
  }
  .collection-list-link {
    font-size: 0.75rem;
  }
}

/* =========================================================
   FOOTER
========================================================= */

.section-footer {
  margin-top: auto;
}

.footer {
  padding: 1.5rem;
  color: var(--r-text);
  background: var(--r-bg);
}

.footer-container {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  overflow: hidden;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius-lg);
  box-shadow: var(--r-shadow);
}

.footer-main {
  display: grid;
  grid-template-columns: minmax(240px, 0.9fr) minmax(0, 2fr);
  gap: clamp(3rem, 7vw, 6rem);
  padding: clamp(2.5rem, 6vw, 5rem);
}

.footer-brand {
  min-width: 0;
}

.footer-logo-link {
  display: inline-flex;
  margin-bottom: 1.25rem;
}

.footer-logo-link:hover {
  opacity: 1;
}

.footer-logo {
  display: block;
  width: auto;
  max-width: 210px;
  max-height: 90px;
}

.footer-shop-name {
  color: var(--r-text-strong);
  font-family: var(--r-font-heading);
  font-size: 2rem;
  font-weight: 700;
}

.footer-description {
  max-width: 360px;
  color: var(--r-muted-dark);
  font-size: 0.95rem;
  line-height: 1.7;
}

.footer-description p {
  margin: 0;
}

.footer-socials {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.65rem;
  margin-top: 1.5rem;
}

.footer-social-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  color: var(--r-primary-dark);
  background: var(--r-surface);
  border: 1px solid var(--r-border);
  border-radius: var(--r-pill);
  transition:
    color 180ms ease,
    background-color 180ms ease,
    border-color 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.footer-social-link:hover {
  color: var(--r-white);
  background: var(--r-primary);
  border-color: var(--r-primary);
  box-shadow: var(--r-shadow);
  opacity: 1;
  transform: translateY(-3px);
}

.footer-social-link .icon,
.footer-social-link svg {
  width: 20px;
  height: 20px;
}

.footer-blocks {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.footer-heading {
  margin: 0 0 1.25rem;
  color: var(--r-text-strong);
  font-size: 1.15rem;
  line-height: 1.2;
  text-align: left;
}

.footer-menu {
  display: grid;
  gap: 0.75rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

.footer-menu-link {
  display: inline-flex;
  color: var(--r-muted-dark);
  font-size: 0.92rem;
  line-height: 1.5;
  transition:
    color 180ms ease,
    transform 180ms ease;
}

.footer-menu-link:hover {
  color: var(--r-primary-dark);
  opacity: 1;
  transform: translateX(4px);
}

.footer-menu-link[aria-current="page"] {
  color: var(--r-primary-dark);
  font-weight: 700;
}

.footer-newsletter {
  grid-column: span 1;
}

.footer-newsletter-text {
  margin-bottom: 1rem;
  color: var(--r-muted-dark);
  font-size: 0.9rem;
  line-height: 1.6;
}

.footer-newsletter-text p {
  margin: 0;
}

.footer-newsletter-field {
  display: flex;
  align-items: stretch;
  gap: 0.5rem;
  padding: 0.4rem;
  background: var(--r-surface);
  border: 1px solid var(--r-border-strong);
  border-radius: var(--r-pill);
  transition:
    border-color 180ms ease,
    box-shadow 180ms ease;
}

.footer-newsletter-field:focus-within {
  border-color: var(--r-primary);
  box-shadow: 0 0 0 4px rgba(142, 115, 216, 0.14);
}

.footer-newsletter-input {
  width: 100%;
  min-width: 0;
  min-height: 44px;
  padding: 0 0.75rem;
  color: var(--r-text);
  background: transparent;
  border: 0;
  outline: none;
}

.footer-newsletter-input::placeholder {
  color: var(--r-muted);
}

.footer-newsletter-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 0.65rem 1.1rem;
  color: var(--r-black);
  font-weight: 700;
  white-space: nowrap;
  background: var(--r-gradient-primary);
  border: 0;
  border-radius: var(--r-pill);
  cursor: pointer;
  transition:
    color 180ms ease,
    background 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.footer-newsletter-button:hover {
  color: var(--r-white);
  background: var(--r-gradient-primary-hover);
  box-shadow: var(--r-shadow);
  transform: translateY(-1px);
}

.footer-form-message {
  margin: 0.75rem 0 0;
  padding: 0.75rem 1rem;
  color: var(--r-text-strong);
  font-size: 0.82rem;
  line-height: 1.5;
  border-radius: 14px;
}

.footer-form-message-error {
  background: var(--r-warning);
}

.footer-form-message-success {
  background: var(--r-success);
}

.footer-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  padding: 1.5rem clamp(2.5rem, 6vw, 5rem);
  background: rgba(255, 251, 255, 0.62);
  border-top: 1px solid var(--r-border);
}

.footer-bottom-content {
  display: grid;
  gap: 0.7rem;
}

.footer-copyright {
  margin: 0;
  color: var(--r-muted-dark);
  font-size: 0.8rem;
  line-height: 1.5;
}

.footer-copyright a {
  color: var(--r-text-strong);
  font-weight: 700;
}

.footer-policy-links {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem 1rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

.footer-policy-links a {
  color: var(--r-muted);
  font-size: 0.75rem;
}

.footer-policy-links a:hover {
  color: var(--r-primary-dark);
}

.footer-payment-icons {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

.footer-payment-icon {
  display: block;
  width: 38px;
  height: auto;
}

/* =========================================================
   FOOTER TABLET
========================================================= */

@media (max-width: 1024px) {
  .footer-main {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .footer-description {
    max-width: 560px;
  }
}

@media (max-width: 768px) {
  .footer {
    padding: 1rem;
  }

  .footer-container {
    border-radius: var(--r-radius);
  }

  .footer-main {
    padding: 3rem 1.5rem;
  }

  .footer-newsletter {
    grid-column: 1 / -1;
  }

  .footer-bottom {
    align-items: flex-start;
    flex-direction: column;
    padding: 1.5rem;
  }

  .footer-payment-icons {
    justify-content: flex-start;
  }
}

/* =========================================================
   FOOTER MOBILE
========================================================= */

@media (max-width: 480px) {
  .footer {
    padding: 0.75rem;
  }

  .footer-main {
    gap: 2.5rem;
    padding: 2.5rem 1.25rem;
  }

  .footer-brand {
    text-align: center;
  }

  .footer-logo-link {
    justify-content: center;
  }

  .footer-description {
    margin: 0 auto;
    font-size: 0.9rem;
  }

  .footer-socials {
    justify-content: center;
  }

  .footer-heading {
    text-align: center;
  }

  .footer-menu {
    justify-items: center;
    text-align: center;
  }

  .footer-newsletter {
    text-align: center;
  }

  .footer-newsletter-field {
    align-items: stretch;
    flex-direction: column;
    padding: 0.5rem;
    border-radius: 18px;
  }

  .footer-newsletter-input {
    min-height: 46px;
    padding: 0 0.75rem;
    font-size: 16px;
    text-align: center;
  }

  .footer-newsletter-button {
    width: 100%;
  }

  .footer-bottom {
    align-items: center;
    padding: 1.25rem;
    text-align: center;
  }

  .footer-policy-links,
  .footer-payment-icons {
    justify-content: center;
  }
}

@media (prefers-reduced-motion: reduce) {
  .footer *,
  .footer *::before,
  .footer *::after {
    transition: none !important;
    animation: none !important;
  }
}

/* =========================================================
   PAGE TEMPLATE
========================================================= */

.page-container {
  width: 100%;
  max-width: 960px;
  margin: 0 auto;
  padding: 4rem 1.5rem 5rem;
}

.page-header {
  max-width: 760px;
  margin: 0 auto 3rem;
  text-align: center;
}

.page-eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 32px;
  margin: 0 0 1rem;
  padding: 0.4rem 0.85rem;
  color: var(--r-primary-dark);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--r-pink-soft);
  border-radius: var(--r-pill);
}

.page-title {
  margin: 0;
  color: var(--r-text-strong);
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  line-height: 1.05;
  overflow-wrap: anywhere;
}

.page-header-divider {
  display: block;
  width: 72px;
  height: 5px;
  margin: 1.5rem auto 0;
  background: var(--r-gradient-primary);
  border-radius: var(--r-pill);
}

.page-content {
  width: 100%;
  padding: clamp(1.5rem, 4vw, 3rem);
  color: var(--r-text);
  font-size: 1rem;
  line-height: 1.8;
  background: var(--r-surface);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius);
  box-shadow: var(--r-shadow);
  overflow-wrap: anywhere;
}

.page-content > *:first-child {
  margin-top: 0;
}

.page-content > *:last-child {
  margin-bottom: 0;
}

.page-content p {
  margin: 0 0 1.5rem;
}

.page-content h2,
.page-content h3,
.page-content h4,
.page-content h5,
.page-content h6 {
  margin: 2.5rem 0 1rem;
  color: var(--r-text-strong);
  line-height: 1.2;
  text-align: left;
  overflow-wrap: anywhere;
}

.page-content h2 {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
}

.page-content h3 {
  font-size: clamp(1.4rem, 3vw, 2rem);
}

.page-content h4 {
  font-size: 1.25rem;
}

.page-content ul,
.page-content ol {
  margin: 1.5rem 0;
  padding-left: 1.5rem;
}

.page-content li {
  margin-bottom: 0.5rem;
}

.page-content a {
  color: var(--r-primary-dark);
  font-weight: 600;
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 3px;
}

.page-content a:hover {
  color: var(--r-pink-dark);
}

.page-content img {
  display: block;
  width: auto;
  max-width: 100%;
  height: auto;
  margin: 2rem auto;
  border-radius: var(--r-radius);
  box-shadow: var(--r-shadow);
}

.page-content blockquote {
  margin: 2rem 0;
  padding: 1.5rem;
  color: var(--r-text);
  background: var(--r-gradient-soft);
  border-left: 4px solid var(--r-primary);
  border-radius: var(--r-radius);
}

.page-content blockquote p:last-child {
  margin-bottom: 0;
}

.page-content hr {
  height: 1px;
  margin: 2.5rem 0;
  background: var(--r-border-strong);
  border: 0;
}

.page-content table {
  display: block;
  width: 100%;
  max-width: 100%;
  margin: 2rem 0;
  overflow-x: auto;
  border-collapse: collapse;
  -webkit-overflow-scrolling: touch;
}

.page-content th,
.page-content td {
  padding: 0.9rem 1rem;
  text-align: left;
  border: 1px solid var(--r-border-strong);
}

.page-content th {
  color: var(--r-text-strong);
  background: var(--r-gradient-soft);
}

.page-content iframe,
.page-content video {
  display: block;
  width: 100%;
  max-width: 100%;
  margin: 2rem 0;
  border: 0;
  border-radius: var(--r-radius);
}

.page-content code {
  padding: 0.15rem 0.4rem;
  font-family: monospace;
  font-size: 0.9em;
  background: var(--r-surface-purple);
  border-radius: 8px;
}

.page-content pre {
  max-width: 100%;
  margin: 2rem 0;
  padding: 1.5rem;
  overflow-x: auto;
  color: var(--r-white);
  background: var(--r-black);
  border-radius: var(--r-radius);
  -webkit-overflow-scrolling: touch;
}

.page-content pre code {
  padding: 0;
  color: inherit;
  background: transparent;
  white-space: pre;
}

.page-empty {
  max-width: 620px;
  margin: 0 auto;
  padding: 3rem 1.5rem;
  text-align: center;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius-lg);
  box-shadow: var(--r-shadow);
}

.page-empty h2 {
  margin: 0 0 0.75rem;
  color: var(--r-text-strong);
}

.page-empty p {
  margin: 0 0 1.5rem;
  color: var(--r-muted-dark);
}

/* =========================================================
   PAGE TABLET
========================================================= */

@media (max-width: 768px) {
  .page-container {
    padding: 2.75rem 1.25rem 4rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: clamp(2rem, 8vw, 2.8rem);
  }

  .page-content {
    padding: 1.75rem;
    border-radius: 20px;
  }

  .page-content h2,
  .page-content h3,
  .page-content h4,
  .page-content h5,
  .page-content h6 {
    margin-top: 2rem;
  }

  .page-content blockquote {
    padding: 1.25rem;
    border-radius: 18px;
  }
}

/* =========================================================
   PAGE MOBILE
========================================================= */

@media (max-width: 480px) {
  .page-container {
    padding: 2rem 0.75rem 3rem;
  }

  .page-header {
    margin-bottom: 1.5rem;
    padding: 0 0.25rem;
  }

  .page-eyebrow {
    margin-bottom: 0.75rem;
    font-size: 0.68rem;
  }

  .page-title {
    font-size: clamp(1.8rem, 10vw, 2.4rem);
  }

  .page-header-divider {
    width: 56px;
    height: 4px;
    margin-top: 1.1rem;
  }

  .page-content {
    padding: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.7;
    border-radius: 18px;
  }

  .page-content p {
    margin-bottom: 1.25rem;
  }

  .page-content ul,
  .page-content ol {
    padding-left: 1.25rem;
  }

  .page-content img {
    margin: 1.5rem auto;
    border-radius: 16px;
  }

  .page-content blockquote {
    margin: 1.5rem 0;
    padding: 1rem;
    border-radius: 14px;
  }

  .page-content pre {
    margin: 1.5rem -0.25rem;
    padding: 1rem;
    border-radius: 14px;
  }

  .page-empty {
    padding: 2rem 1rem;
    border-radius: 18px;
  }
}

/* =========================================================
   CONTACT FORM
========================================================= */

.contact-section {
  padding: 4rem 1.5rem 5rem;
}

.contact-container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
}

.contact-header {
  max-width: 760px;
  margin: 0 auto 3rem;
  text-align: center;
}

.contact-eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 32px;
  margin: 0 0 1rem;
  padding: 0.4rem 0.85rem;
  color: var(--r-primary-dark);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--r-pink-soft);
  border-radius: var(--r-pill);
}

.contact-title {
  margin: 0;
  color: var(--r-text-strong);
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  line-height: 1.05;
}

.contact-description {
  max-width: 650px;
  margin: 1rem auto 0;
  color: var(--r-muted-dark);
  font-size: 1rem;
  line-height: 1.75;
}

.contact-description p {
  margin: 0;
}

/* =========================================================
   CONTACT LAYOUT
========================================================= */

.contact-layout {
  display: grid;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
  gap: 2rem;
  align-items: stretch;
}

.contact-layout-full {
  grid-template-columns: minmax(0, 820px);
  justify-content: center;
}

/* =========================================================
   CONTACT IMAGE
========================================================= */

.contact-media {
  position: relative;
  min-height: 100%;
  overflow: hidden;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius-lg);
  box-shadow: var(--r-shadow);
}

.contact-image {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 640px;
  object-fit: cover;
}

.contact-media-content {
  position: absolute;
  right: 1.5rem;
  bottom: 1.5rem;
  left: 1.5rem;
  padding: 1.25rem;
  color: var(--r-white);
  font-size: 0.95rem;
  line-height: 1.65;
  background: rgba(36, 31, 53, 0.58);
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: 20px;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.contact-media-content p {
  margin: 0;
}

/* =========================================================
   CONTACT PANEL
========================================================= */

.contact-panel {
  min-width: 0;
  padding: clamp(1.5rem, 4vw, 2.5rem);
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius-lg);
  box-shadow: var(--r-shadow);
}

.contact-form-title {
  margin: 0 0 0.75rem;
  color: var(--r-text-strong);
  font-size: clamp(1.5rem, 3vw, 2rem);
  text-align: left;
}

.contact-form-intro {
  margin-bottom: 1.75rem;
  color: var(--r-muted-dark);
  font-size: 0.95rem;
  line-height: 1.7;
}

.contact-form-intro p {
  margin: 0;
}

/* =========================================================
   CONTACT FIELDS
========================================================= */

.contact-fields {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1.25rem;
}

.contact-field {
  min-width: 0;
}

.contact-field-full {
  grid-column: 1 / -1;
}

.contact-label {
  display: block;
  margin-bottom: 0.5rem;
  color: var(--r-text-strong);
  font-size: 0.88rem;
  font-weight: 700;
}

.contact-input,
.contact-textarea {
  display: block;
  width: 100%;
  min-width: 0;
  padding: 0.85rem 1rem;
  color: var(--r-text);
  font-family: inherit;
  font-size: 1rem;
  line-height: 1.5;
  background: var(--r-surface);
  border: 1px solid var(--r-border-strong);
  border-radius: 16px;
  box-sizing: border-box;
  transition:
    border-color 180ms ease,
    background-color 180ms ease,
    box-shadow 180ms ease;
}

.contact-input {
  min-height: 48px;
}

.contact-textarea {
  min-height: 180px;
  resize: vertical;
}

.contact-input::placeholder,
.contact-textarea::placeholder {
  color: var(--r-muted);
}

.contact-input:hover,
.contact-textarea:hover {
  background: var(--r-surface-purple);
}

.contact-input:focus,
.contact-textarea:focus {
  background: var(--r-surface);
  border-color: var(--r-primary);
  outline: none;
  box-shadow: 0 0 0 4px rgba(142, 115, 216, 0.14);
}

.contact-input[aria-invalid="true"],
.contact-textarea[aria-invalid="true"] {
  border-color: #a64c3c;
}

.contact-field-error {
  display: block;
  margin-top: 0.45rem;
  color: #a64c3c;
  font-size: 0.8rem;
  line-height: 1.4;
}

/* =========================================================
   CONTACT MESSAGES
========================================================= */

.contact-message {
  margin-bottom: 1.5rem;
  padding: 1rem 1.25rem;
  color: var(--r-text-strong);
  border-radius: 16px;
}

.contact-message strong {
  display: block;
  margin-bottom: 0.25rem;
}

.contact-message p {
  margin: 0;
}

.contact-message-success {
  background: var(--r-success);
}

.contact-message-error {
  background: var(--r-warning);
}

.contact-error-list {
  margin: 0.75rem 0 0;
  padding-left: 1.25rem;
}

.contact-error-list li {
  margin-bottom: 0.35rem;
}

.contact-error-list li:last-child {
  margin-bottom: 0;
}

.contact-error-list a {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* =========================================================
   CONTACT PRIVACY AND BUTTON
========================================================= */

.contact-privacy {
  margin-top: 1.25rem;
  color: var(--r-muted);
  font-size: 0.8rem;
  line-height: 1.6;
}

.contact-privacy p {
  margin: 0;
}

.contact-privacy a {
  color: var(--r-primary-dark);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.contact-submit {
  margin-top: 1.5rem;
}

/* =========================================================
   CONTACT DETAILS
========================================================= */

.contact-details {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid var(--r-border-strong);
}

.contact-detail {
  min-width: 0;
  padding: 1.1rem;
  background: var(--r-surface);
  border: 1px solid var(--r-border);
  border-radius: 18px;
}

.contact-detail-title {
  margin: 0 0 0.5rem;
  color: var(--r-text-strong);
  font-size: 1rem;
  text-align: left;
}

.contact-detail-text {
  color: var(--r-muted-dark);
  font-size: 0.85rem;
  line-height: 1.6;
  overflow-wrap: anywhere;
}

.contact-detail-text p {
  margin: 0;
}

.contact-detail-link {
  display: inline-flex;
  margin-top: 0.7rem;
  color: var(--r-primary-dark);
  font-size: 0.82rem;
  font-weight: 700;
  text-decoration: underline;
  text-underline-offset: 3px;
  overflow-wrap: anywhere;
}

/* =========================================================
   CONTACT TABLET
========================================================= */

@media (max-width: 900px) {
  .contact-layout {
    grid-template-columns: 1fr;
  }

  .contact-image {
    min-height: 420px;
    max-height: 520px;
  }
}

@media (max-width: 768px) {
  .contact-section {
    padding: 2.75rem 1.25rem 4rem;
  }

  .contact-header {
    margin-bottom: 2rem;
  }

  .contact-title {
    font-size: clamp(2rem, 8vw, 2.8rem);
  }

  .contact-panel,
  .contact-media {
    border-radius: 22px;
  }

  .contact-fields {
    grid-template-columns: 1fr;
  }

  .contact-field-full {
    grid-column: auto;
  }

  .contact-details {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

/* =========================================================
   CONTACT MOBILE
========================================================= */

@media (max-width: 480px) {
  .contact-section {
    padding: 2rem 0.75rem 3rem;
  }

  .contact-header {
    margin-bottom: 1.5rem;
    padding: 0 0.25rem;
  }

  .contact-eyebrow {
    margin-bottom: 0.75rem;
    font-size: 0.68rem;
  }

  .contact-title {
    font-size: clamp(1.8rem, 10vw, 2.4rem);
  }

  .contact-description {
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .contact-image {
    min-height: 320px;
    max-height: 400px;
  }

  .contact-media-content {
    right: 0.75rem;
    bottom: 0.75rem;
    left: 0.75rem;
    padding: 1rem;
    border-radius: 16px;
  }

  .contact-panel {
    padding: 1.25rem;
    border-radius: 18px;
  }

  .contact-form-title {
    text-align: center;
  }

  .contact-form-intro {
    text-align: center;
  }

  .contact-input,
  .contact-textarea {
    padding: 0.8rem 0.9rem;
    font-size: 16px;
    border-radius: 14px;
  }

  .contact-textarea {
    min-height: 160px;
  }

  .contact-submit {
    width: 100%;
  }

  .contact-details {
    grid-template-columns: 1fr;
  }

  .contact-detail {
    text-align: center;
  }

  .contact-detail-title {
    text-align: center;
  }
}

/* =========================================================
   PRODUCT TEMPLATE
========================================================= */

.reimii-product {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 4rem 1.5rem 6rem;
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(360px, 0.85fr);
  gap: clamp(2rem, 5vw, 5rem);
  align-items: start;
  color: var(--r-text);
}

.reimii-product__left,
.reimii-product__info {
  min-width: 0;
}

/* =========================================================
   PRODUCT GALLERY
========================================================= */

.reimii-gallery {
  position: relative;
  min-width: 0;
}

.reimii-product__gallery {
  display: flex;
  gap: 1rem;
  width: 100%;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scrollbar-width: none;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius-lg);
  box-shadow: var(--r-shadow);
  overscroll-behavior-inline: contain;
  -webkit-overflow-scrolling: touch;
}

.reimii-product__gallery::-webkit-scrollbar {
  display: none;
}

.reimii-product__image {
  display: block;
  width: 100%;
  min-width: 100%;
  aspect-ratio: 1 / 1;
  flex: 0 0 100%;
  object-fit: cover;
  scroll-snap-align: start;
  scroll-snap-stop: always;
  background: var(--r-bg-alt);
}

.reimii-gallery-arrow {
  position: absolute;
  top: 50%;
  z-index: 3;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  padding: 0;
  color: var(--r-primary-dark);
  font-size: 1.3rem;
  font-weight: 700;
  line-height: 1;
  background: rgba(255, 251, 255, 0.9);
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: var(--r-pill);
  box-shadow: var(--r-shadow);
  cursor: pointer;
  transform: translateY(-50%);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition:
    color 180ms ease,
    background 180ms ease,
    border-color 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.reimii-gallery-arrow:hover {
  color: var(--r-white);
  background: var(--r-primary);
  border-color: var(--r-primary);
  box-shadow: var(--r-shadow-hover);
  transform: translateY(-50%) scale(1.05);
}

.reimii-gallery-arrow:active {
  transform: translateY(-50%) scale(0.98);
}

.reimii-gallery-arrow.prev {
  left: 1rem;
}

.reimii-gallery-arrow.next {
  right: 1rem;
}

/* =========================================================
   PRODUCT INFORMATION CARD
========================================================= */

.reimii-product__info {
  position: sticky;
  top: 2rem;
  padding: clamp(1.5rem, 3vw, 2.5rem);
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius-lg);
  box-shadow: var(--r-shadow);
}

.reimii-product__kicker {
  display: inline-flex;
  align-items: center;
  min-height: 32px;
  margin: 0 0 1rem;
  padding: 0.4rem 0.85rem;
  color: var(--r-primary-dark);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  background: var(--r-pink-soft);
  border-radius: var(--r-pill);
}

.reimii-product__info h1 {
  margin: 0 0 1rem;
  color: var(--r-text-strong);
  font-size: clamp(2rem, 4vw, 3.25rem);
  line-height: 1.05;
  text-align: left;
  text-wrap: balance;
  overflow-wrap: anywhere;
}

/* =========================================================
   PRODUCT PRICE
========================================================= */

.reimii-product__price {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0.7rem;
  margin-bottom: 1.5rem;
  color: var(--r-primary-dark);
}

.reimii-product__price span {
  font-family: var(--r-font-heading);
  font-size: clamp(1.65rem, 3vw, 2.25rem);
  font-weight: 700;
  line-height: 1;
}

.reimii-product__price s {
  color: var(--r-muted);
  font-size: 1rem;
  font-weight: 500;
}

/* =========================================================
   PRODUCT TRUST BENEFITS
========================================================= */

.reimii-product__trust {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.65rem;
  margin-bottom: 1.75rem;
}

.reimii-product__trust span {
  display: flex;
  align-items: center;
  min-width: 0;
  min-height: 46px;
  padding: 0.7rem 0.85rem;
  color: var(--r-muted-dark);
  font-size: 0.78rem;
  font-weight: 600;
  line-height: 1.35;
  background: rgba(255, 251, 255, 0.78);
  border: 1px solid var(--r-border);
  border-radius: 15px;
}

/* =========================================================
   PRODUCT FORM
========================================================= */

.reimii-product__form {
  margin-bottom: 1.75rem;
}

.reimii-product__form form {
  display: grid;
  gap: 1rem;
}

.reimii-variant-groups {
  display: grid;
  gap: 1.4rem;
}

.reimii-option-group {
  min-width: 0;
}

.reimii-option-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 0.7rem;
  color: var(--r-text-strong);
  font-size: 0.9rem;
  font-weight: 700;
}

.reimii-option-header strong {
  color: var(--r-primary-dark);
  font-size: 0.82rem;
  text-align: right;
}

.reimii-option-values {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.65rem;
}

.reimii-option {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 0.65rem 1rem;
  color: var(--r-text);
  font-size: 0.85rem;
  font-weight: 700;
  line-height: 1.2;
  background: var(--r-surface);
  border: 1px solid var(--r-border-strong);
  border-radius: var(--r-pill);
  cursor: pointer;
  transition:
    color 180ms ease,
    background 180ms ease,
    border-color 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.reimii-option:hover {
  color: var(--r-primary-dark);
  background: var(--r-surface-purple);
  border-color: var(--r-primary-soft);
  box-shadow: 0 6px 18px rgba(116, 87, 199, 0.12);
  transform: translateY(-1px);
}

.reimii-option.is-active {
  color: var(--r-black);
  background: var(--r-gradient-primary);
  border-color: transparent;
  box-shadow: 0 8px 20px rgba(116, 87, 199, 0.2);
}

.reimii-option.is-active:hover {
  color: var(--r-black);
  background: var(--r-gradient-primary);
}

.reimii-product__quantity {
  width: 90px;
  min-height: 48px;
  padding: 0.7rem 0.75rem;
  color: var(--r-text-strong);
  font-size: 1rem;
  font-weight: 700;
  text-align: center;
  background: var(--r-surface);
  border: 1px solid var(--r-border-strong);
  border-radius: 16px;
  box-sizing: border-box;
  transition:
    border-color 180ms ease,
    background-color 180ms ease,
    box-shadow 180ms ease;
}

.reimii-product__quantity:hover {
  background: var(--r-surface-purple);
}

.reimii-product__quantity:focus {
  background: var(--r-surface);
  border-color: var(--r-primary);
  outline: none;
  box-shadow: 0 0 0 4px rgba(142, 115, 216, 0.14);
}

.reimii-product__submit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 54px;
  padding: 0.85rem 1.5rem;
  color: var(--r-black);
  font-size: 1rem;
  font-weight: 700;
  background: var(--r-gradient-primary);
  border: 0;
  border-radius: var(--r-pill);
  box-shadow: 0 10px 28px rgba(116, 87, 199, 0.22);
  cursor: pointer;
  transition:
    color 180ms ease,
    background 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.reimii-product__submit:hover {
  color: var(--r-white);
  background: var(--r-gradient-primary-hover);
  box-shadow: var(--r-shadow-hover);
  transform: translateY(-2px);
}

.reimii-product__submit:active {
  transform: translateY(0);
}

.reimii-product__submit:disabled {
  color: var(--r-muted);
  background: var(--r-disabled);
  box-shadow: none;
  cursor: not-allowed;
  transform: none;
}

/* =========================================================
   SHOP PAY
========================================================= */

.reimii-shop-pay {
  width: 100%;
}

.reimii-shop-pay .shopify-payment-button {
  width: 100%;
}

.reimii-shop-pay .shopify-payment-button__button {
  min-height: 52px !important;
  overflow: hidden;
  font-family: var(--r-font-body) !important;
  font-size: 0.95rem !important;
  font-weight: 700 !important;
  border-radius: var(--r-pill) !important;
}

.reimii-shop-pay .shopify-payment-button__button--unbranded {
  color: var(--r-primary-dark) !important;
  background: var(--r-surface) !important;
  border: 1px solid var(--r-primary-soft) !important;
  box-shadow: none !important;
}

.reimii-shop-pay .shopify-payment-button__button--unbranded:hover {
  color: var(--r-primary-dark) !important;
  background: var(--r-surface-purple) !important;
  border-color: var(--r-primary) !important;
}

/* =========================================================
   PRODUCT ACCORDIONS
========================================================= */

.reimii-product__accordions {
  display: grid;
  gap: 0.75rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--r-border-strong);
}

.reimii-product__accordions details {
  overflow: hidden;
  background: rgba(255, 251, 255, 0.75);
  border: 1px solid var(--r-border);
  border-radius: 17px;
  transition:
    border-color 180ms ease,
    background-color 180ms ease,
    box-shadow 180ms ease;
}

.reimii-product__accordions details:hover {
  background: var(--r-surface);
  border-color: var(--r-primary-soft);
}

.reimii-product__accordions details[open] {
  background: var(--r-surface);
  border-color: var(--r-primary-soft);
  box-shadow: 0 8px 24px rgba(116, 87, 199, 0.08);
}

.reimii-product__accordions summary {
  position: relative;
  padding: 1rem 3rem 1rem 1rem;
  color: var(--r-text-strong);
  font-size: 0.9rem;
  font-weight: 700;
  list-style: none;
  cursor: pointer;
}

.reimii-product__accordions summary::-webkit-details-marker {
  display: none;
}

.reimii-product__accordions summary::after {
  content: "+";
  position: absolute;
  top: 50%;
  right: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  color: var(--r-primary-dark);
  font-size: 1.15rem;
  font-weight: 500;
  background: var(--r-surface-purple);
  border-radius: var(--r-pill);
  transform: translateY(-50%);
  transition:
    color 180ms ease,
    background-color 180ms ease,
    transform 180ms ease;
}

.reimii-product__accordions details[open] summary::after {
  content: "−";
  color: var(--r-white);
  background: var(--r-primary);
  transform: translateY(-50%) rotate(180deg);
}

.reimii-product__accordions details p {
  margin: 0;
  padding: 0 1rem 1rem;
  color: var(--r-muted-dark);
  font-size: 0.86rem;
  line-height: 1.7;
}

/* =========================================================
   PRODUCT DESCRIPTION
========================================================= */

.reimii-product__description-desktop {
  margin-top: 2rem;
  padding: clamp(1.5rem, 3vw, 2.25rem);
  color: var(--r-text);
  font-size: 0.98rem;
  line-height: 1.8;
  background: var(--r-surface);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius);
  box-shadow: var(--r-shadow);
  overflow-wrap: anywhere;
}

.reimii-product__description-mobile {
  display: none;
}

.reimii-product__description-desktop > *:first-child,
.reimii-product__description-mobile > *:first-child {
  margin-top: 0;
}

.reimii-product__description-desktop > *:last-child,
.reimii-product__description-mobile > *:last-child {
  margin-bottom: 0;
}

.reimii-product__description-desktop p,
.reimii-product__description-mobile p {
  margin: 0 0 1.25rem;
}

.reimii-product__description-desktop h2,
.reimii-product__description-desktop h3,
.reimii-product__description-desktop h4,
.reimii-product__description-mobile h2,
.reimii-product__description-mobile h3,
.reimii-product__description-mobile h4 {
  margin: 2rem 0 0.85rem;
  color: var(--r-text-strong);
  text-align: left;
}

.reimii-product__description-desktop h2,
.reimii-product__description-mobile h2 {
  font-size: clamp(1.5rem, 3vw, 2rem);
}

.reimii-product__description-desktop h3,
.reimii-product__description-mobile h3 {
  font-size: 1.3rem;
}

.reimii-product__description-desktop ul,
.reimii-product__description-desktop ol,
.reimii-product__description-mobile ul,
.reimii-product__description-mobile ol {
  margin: 1.25rem 0;
  padding-left: 1.4rem;
}

.reimii-product__description-desktop li,
.reimii-product__description-mobile li {
  margin-bottom: 0.5rem;
}

.reimii-product__description-desktop img,
.reimii-product__description-mobile img {
  display: block;
  width: auto;
  max-width: 100%;
  height: auto;
  margin: 1.5rem auto;
  border-radius: 18px;
}

.reimii-product__description-desktop a,
.reimii-product__description-mobile a {
  color: var(--r-primary-dark);
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* =========================================================
   STICKY ADD TO CART
========================================================= */

.reimii-sticky-atc {
  position: fixed;
  right: 90px;
  bottom: 1rem;
  left: 1rem;
  z-index: 40;
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  max-width: 620px;
  margin: 0 auto;
  padding: 0.75rem;
  background: rgba(255, 251, 255, 0.92);
  border: 1px solid rgba(142, 115, 216, 0.16);
  border-radius: 20px;
  box-shadow: var(--r-shadow-strong);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.reimii-sticky-atc > div {
  min-width: 0;
  padding-left: 0.35rem;
}

.reimii-sticky-atc strong {
  display: block;
  max-width: 320px;
  color: var(--r-text-strong);
  font-size: 0.8rem;
  line-height: 1.25;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.reimii-sticky-atc span {
  display: block;
  margin-top: 0.2rem;
  color: var(--r-primary-dark);
  font-size: 0.82rem;
  font-weight: 700;
}

.reimii-sticky-atc form {
  flex-shrink: 0;
}

.reimii-sticky-atc button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 0.7rem 1.25rem;
  color: var(--r-black);
  font-weight: 700;
  background: var(--r-gradient-primary);
  border: 0;
  border-radius: var(--r-pill);
  box-shadow: 0 6px 18px rgba(116, 87, 199, 0.2);
  cursor: pointer;
  transition:
    color 180ms ease,
    background 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.reimii-sticky-atc button:hover {
  color: var(--r-white);
  background: var(--r-gradient-primary-hover);
  box-shadow: var(--r-shadow-hover);
  transform: translateY(-1px);
}

/* =========================================================
   PRODUCT TABLET
========================================================= */

@media (max-width: 960px) {
  .reimii-product {
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.85fr);
    gap: 2rem;
    padding: 3rem 1.25rem 5rem;
  }

  .reimii-product__info {
    top: 1rem;
    padding: 1.5rem;
    border-radius: var(--r-radius);
  }

  .reimii-product__trust {
    grid-template-columns: 1fr;
  }

  .reimii-product__trust span {
    min-height: 42px;
  }
}

/* =========================================================
   PRODUCT MOBILE
========================================================= */

@media (max-width: 768px) {
  .reimii-product {
    display: block;
    padding: 1.5rem 1rem 8rem;
  }

  .reimii-product__left,
  .reimii-product__info {
    width: 100%;
  }

  .reimii-product__gallery {
    border-radius: 22px;
  }

  .reimii-gallery-arrow {
    width: 42px;
    height: 42px;
  }

  .reimii-gallery-arrow.prev {
    left: 0.75rem;
  }

  .reimii-gallery-arrow.next {
    right: 0.75rem;
  }

  .reimii-product__info {
    position: static;
    margin-top: 1.25rem;
    padding: 1.5rem;
    border-radius: 22px;
  }

  .reimii-product__info h1 {
    font-size: clamp(1.9rem, 8vw, 2.6rem);
  }

  .reimii-product__trust {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .reimii-product__description-desktop {
    display: none;
  }

  .reimii-product__description-mobile {
    display: block;
    margin-top: 1.25rem;
    padding: 1.5rem;
    color: var(--r-text);
    font-size: 0.95rem;
    line-height: 1.75;
    background: var(--r-surface);
    border: 1px solid var(--r-border);
    border-radius: 22px;
    box-shadow: var(--r-shadow);
    overflow-wrap: anywhere;
  }

  .reimii-sticky-atc {
    display: flex;
  }
}

@media (max-width: 480px) {
  .reimii-product {
    padding: 1rem 0.75rem 7.5rem;
  }

  .reimii-product__gallery {
    gap: 0;
    border-radius: 18px;
  }

  .reimii-gallery-arrow {
    width: 38px;
    height: 38px;
    font-size: 1.05rem;
  }

  .reimii-gallery-arrow.prev {
    left: 0.5rem;
  }

  .reimii-gallery-arrow.next {
    right: 0.5rem;
  }

  .reimii-product__info {
    margin-top: 1rem;
    padding: 1.25rem;
    border-radius: 18px;
  }

  .reimii-product__kicker {
    margin-bottom: 0.75rem;
    font-size: 0.65rem;
  }

  .reimii-product__info h1 {
    margin-bottom: 0.85rem;
    font-size: clamp(1.7rem, 9vw, 2.2rem);
  }

  .reimii-product__price {
    margin-bottom: 1.25rem;
  }

  .reimii-product__price span {
    font-size: 1.65rem;
  }

  .reimii-product__trust {
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  .reimii-product__trust span {
    min-height: 40px;
    padding: 0.65rem 0.75rem;
    font-size: 0.75rem;
    border-radius: 13px;
  }

  .reimii-option-header {
    align-items: flex-start;
    flex-direction: column;
    gap: 0.2rem;
  }

  .reimii-option-header strong {
    text-align: left;
  }

  .reimii-option-values {
    gap: 0.5rem;
  }

  .reimii-option {
    min-height: 40px;
    padding: 0.6rem 0.85rem;
    font-size: 0.8rem;
  }

  .reimii-product__quantity {
    width: 82px;
    min-height: 46px;
    font-size: 16px;
    border-radius: 14px;
  }

  .reimii-product__submit {
    min-height: 52px;
    font-size: 0.95rem;
  }

  .reimii-product__accordions summary {
    padding: 0.9rem 2.8rem 0.9rem 0.9rem;
    font-size: 0.85rem;
  }

  .reimii-product__accordions details p {
    padding: 0 0.9rem 0.9rem;
    font-size: 0.82rem;
  }

  .reimii-product__description-mobile {
    padding: 1.25rem;
    font-size: 0.92rem;
    line-height: 1.7;
    border-radius: 18px;
  }

  .reimii-sticky-atc {
    right: 0.6rem;
    bottom: 0.6rem;
    left: 0.6rem;
    gap: 0.5rem;
    padding: 0.6rem;
    border-radius: 17px;
  }

  .reimii-sticky-atc strong {
    max-width: 180px;
    font-size: 0.72rem;
  }

  .reimii-sticky-atc span {
    font-size: 0.75rem;
  }

  .reimii-sticky-atc button {
    min-height: 42px;
    padding: 0.65rem 1rem;
    font-size: 0.82rem;
  }
}

/* =========================================================
   PRODUCT REDUCED MOTION
========================================================= */

@media (prefers-reduced-motion: reduce) {
  .reimii-product *,
  .reimii-product *::before,
  .reimii-product *::after,
  .reimii-sticky-atc *,
  .reimii-sticky-atc *::before,
  .reimii-sticky-atc *::after {
    scroll-behavior: auto !important;
    transition: none !important;
    animation: none !important;
  }
}

/* =========================================================
   SEARCH TEMPLATE
========================================================= */

.reimii-search {
  width: 100%;
  padding: 4rem 1.5rem 6rem;
}

.reimii-search__container {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
}

/* =========================================================
   SEARCH HEADER
========================================================= */

.reimii-search__header {
  max-width: 900px;
  margin: 0 auto 3rem;
  padding: clamp(1.75rem, 5vw, 3.5rem);
  text-align: center;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius-lg);
  box-shadow: var(--r-shadow);
}

.reimii-search__eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 32px;
  margin: 0 0 1rem;
  padding: 0.4rem 0.85rem;
  color: var(--r-primary-dark);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  background: var(--r-pink-soft);
  border-radius: var(--r-pill);
}

.reimii-search__title {
  margin: 0;
  color: var(--r-text-strong);
  font-size: clamp(2.25rem, 6vw, 4rem);
  line-height: 1.05;
  text-align: center;
  text-wrap: balance;
}

.reimii-search__intro {
  max-width: 600px;
  margin: 1rem auto 0;
  color: var(--r-muted-dark);
  font-size: 1rem;
  line-height: 1.7;
}

/* =========================================================
   SEARCH FORM
========================================================= */

.reimii-search__form {
  width: 100%;
  max-width: 720px;
  margin: 2rem auto 0;
}

.reimii-search__field {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.45rem;
  background: var(--r-surface);
  border: 1px solid var(--r-border-strong);
  border-radius: var(--r-pill);
  box-shadow: 0 10px 30px rgba(116, 87, 199, 0.1);
  transition:
    border-color 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.reimii-search__field:focus-within {
  border-color: var(--r-primary);
  box-shadow:
    0 0 0 4px rgba(142, 115, 216, 0.14),
    var(--r-shadow);
  transform: translateY(-1px);
}

.reimii-search__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 44px;
  width: 44px;
  height: 44px;
  color: var(--r-primary-dark);
}

.reimii-search__icon svg {
  width: 21px;
  height: 21px;
}

.reimii-search__input {
  width: 100%;
  min-width: 0;
  min-height: 48px;
  padding: 0 0.5rem;
  color: var(--r-text);
  font-family: var(--r-font-body);
  font-size: 1rem;
  background: transparent;
  border: 0;
  outline: 0;
  appearance: none;
}

.reimii-search__input::-webkit-search-cancel-button {
  cursor: pointer;
}

.reimii-search__input::placeholder {
  color: var(--r-muted);
}

.reimii-search__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-height: 48px;
  padding: 0.75rem 1.6rem;
  color: var(--r-black);
  font-weight: 700;
  background: var(--r-gradient-primary);
  border: 0;
  border-radius: var(--r-pill);
  box-shadow: 0 8px 22px rgba(116, 87, 199, 0.18);
  cursor: pointer;
  transition:
    color 180ms ease,
    background 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.reimii-search__button:hover {
  color: var(--r-white);
  background: var(--r-gradient-primary-hover);
  box-shadow: var(--r-shadow-hover);
  transform: translateY(-1px);
}

.reimii-search__button:active {
  transform: translateY(0);
}

.reimii-search__summary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 1.5rem;
  padding: 0.55rem 1rem;
  color: var(--r-muted-dark);
  font-size: 0.85rem;
  line-height: 1.4;
  background: rgba(255, 251, 255, 0.72);
  border: 1px solid var(--r-border);
  border-radius: var(--r-pill);
}

.reimii-search__summary strong {
  margin-left: 0.25rem;
  color: var(--r-primary-dark);
}

/* =========================================================
   SEARCH RESULTS GRID
========================================================= */

.reimii-search__results {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 2rem;
}

.reimii-search-card {
  position: relative;
  min-width: 0;
  overflow: hidden;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius);
  transition:
    transform 280ms cubic-bezier(0.22, 1, 0.36, 1),
    border-color 280ms ease,
    box-shadow 280ms ease;
}

.reimii-search-card:hover {
  border-color: var(--r-primary);
  box-shadow: var(--r-shadow-hover);
  transform: translateY(-6px);
}

.reimii-search-card__link {
  display: flex;
  flex-direction: column;
  height: 100%;
  color: inherit;
}

.reimii-search-card__link:hover {
  color: inherit;
  opacity: 1;
}

/* =========================================================
   SEARCH CARD MEDIA
========================================================= */

.reimii-search-card__media {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  background: var(--r-bg-alt);
}

.reimii-search-card__image {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition:
    transform 450ms cubic-bezier(0.22, 1, 0.36, 1),
    filter 350ms ease;
}

.reimii-search-card:hover .reimii-search-card__image {
  filter: brightness(1.04) saturate(1.05);
  transform: scale(1.06);
}

.reimii-search-card__placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background: var(--r-gradient-story);
}

.reimii-search-card__placeholder span {
  font-size: clamp(3rem, 7vw, 5rem);
  filter: drop-shadow(0 10px 18px rgba(116, 87, 199, 0.15));
  transition: transform 280ms ease;
}

.reimii-search-card:hover .reimii-search-card__placeholder span {
  transform: scale(1.08) rotate(-3deg);
}

.reimii-search-card__type {
  position: absolute;
  top: 0.75rem;
  left: 0.75rem;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  min-height: 28px;
  padding: 0.35rem 0.7rem;
  color: var(--r-primary-dark);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  background: rgba(255, 251, 255, 0.88);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-radius: var(--r-pill);
  box-shadow: var(--r-shadow);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.reimii-search-card__badge {
  position: absolute;
  top: 0.75rem;
  right: 0.75rem;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  min-height: 28px;
  padding: 0.35rem 0.7rem;
  font-size: 0.65rem;
  font-weight: 700;
  border-radius: var(--r-pill);
}

.reimii-search-card__badge--sale {
  color: var(--r-white);
  background: var(--r-gradient-primary);
}

.reimii-search-card__badge--sold-out {
  color: var(--r-muted-dark);
  background: var(--r-disabled);
}

/* =========================================================
   SEARCH CARD CONTENT
========================================================= */

.reimii-search-card__content {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  padding: 1.2rem;
}

.reimii-search-card__vendor {
  margin: 0 0 0.35rem;
  color: var(--r-muted);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.reimii-search-card__title {
  margin: 0 0 0.75rem;
  color: var(--r-text-strong);
  font-family: var(--r-font-heading);
  font-size: 1.05rem;
  line-height: 1.3;
  text-align: left;
  overflow-wrap: anywhere;
  transition: color 180ms ease;
}

.reimii-search-card:hover .reimii-search-card__title {
  color: var(--r-primary-dark);
}

.reimii-search-card__price {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0.45rem;
  margin-top: auto;
}

.reimii-search-card__price-prefix {
  color: var(--r-muted);
  font-size: 0.75rem;
}

.reimii-search-card__current-price {
  color: var(--r-primary-dark);
  font-size: 1rem;
  font-weight: 700;
}

.reimii-search-card__compare-price {
  color: var(--r-muted);
  font-size: 0.8rem;
}

.reimii-search-card__excerpt {
  margin-bottom: 1rem;
  color: var(--r-muted-dark);
  font-size: 0.84rem;
  line-height: 1.6;
}

.reimii-search-card__excerpt p {
  margin: 0;
}

.reimii-search-card__read-more {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: auto;
  color: var(--r-primary-dark);
  font-size: 0.82rem;
  font-weight: 700;
}

.reimii-search-card__read-more span {
  transition: transform 180ms ease;
}

.reimii-search-card:hover .reimii-search-card__read-more span {
  transform: translateX(4px);
}

/* =========================================================
   SEARCH EMPTY AND START STATES
========================================================= */

.reimii-search-empty,
.reimii-search-start {
  max-width: 720px;
  margin: 0 auto;
  padding: clamp(2rem, 6vw, 4rem);
  text-align: center;
  background: var(--r-gradient-soft);
  border: 1px solid var(--r-border);
  border-radius: var(--r-radius-lg);
  box-shadow: var(--r-shadow);
}

.reimii-search-empty__icon,
.reimii-search-start__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 11px;
  width: 86px;
  height: 86px;
  margin: 0 auto 1.5rem;
  font-size: 2.4rem;
  background: var(--r-surface);
  border: 1px solid var(--r-border);
  border-radius: 28px;
  box-shadow: var(--r-shadow);
  transform: rotate(-4deg);
}

.reimii-search-empty h2,
.reimii-search-start h2 {
  margin: 0 0 0.75rem;
  color: var(--r-text-strong);
  font-size: clamp(1.75rem, 4vw, 2.5rem);
}

.reimii-search-empty > p,
.reimii-search-start > p {
  max-width: 540px;
  margin: 0 auto;
  color: var(--r-muted-dark);
  line-height: 1.7;
}

.reimii-search-empty__suggestions {
  margin-top: 2rem;
}

.reimii-search-empty__suggestions > span {
  display: block;
  margin-bottom: 0.75rem;
  color: var(--r-muted);
  font-size: 0.8rem;
  font-weight: 700;
}

.reimii-search-empty__suggestions > div,
.reimii-search-start__links {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0.6rem;
}

.reimii-search-empty__suggestions a,
.reimii-search-start__links a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38px;
  padding: 0.55rem 0.9rem;
  color: var(--r-primary-dark);
  font-size: 0.8rem;
  font-weight: 700;
  background: var(--r-surface);
  border: 1px solid var(--r-primary-soft);
  border-radius: var(--r-pill);
  transition:
    color 180ms ease,
    background-color 180ms ease,
    border-color 180ms ease,
    box-shadow 180ms ease,
    transform 180ms ease;
}

.reimii-search-empty__suggestions a:hover,
.reimii-search-start__links a:hover {
  color: var(--r-white);
  background: var(--r-primary);
  border-color: var(--r-primary);
  box-shadow: var(--r-shadow);
  opacity: 1;
  transform: translateY(-2px);
}

.reimii-search-empty__button {
  margin-top: 2rem;
}

.reimii-search-start__links {
  margin-top: 2rem;
}

/* =========================================================
   SEARCH PAGINATION
========================================================= */

.reimii-search__pagination {
  margin-top: 3rem;
  text-align: center;
}

.reimii-search__pagination .page,
.reimii-search__pagination .next,
.reimii-search__pagination .prev {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 42px;
  min-height: 42px;
  margin: 0.2rem;
  padding: 0.5rem 0.8rem;
  color: var(--r-text);
  background: var(--r-surface);
  border: 1px solid var(--r-border);
  border-radius: var(--r-pill);
  transition:
    color 180ms ease,
    background-color 180ms ease,
    border-color 180ms ease,
    transform 180ms ease;
}

.reimii-search__pagination a {
  display: flex;
  align-items: center;
  justify-content: center;
  color: inherit;
}

.reimii-search__pagination .page:hover,
.reimii-search__pagination .next:hover,
.reimii-search__pagination .prev:hover {
  color: var(--r-primary-dark);
  background: var(--r-surface-purple);
  border-color: var(--r-primary-soft);
  transform: translateY(-2px);
}

.reimii-search__pagination .current {
  color: var(--r-black);
  font-weight: 700;
  background: var(--r-gradient-primary);
  border-color: transparent;
}

/* =========================================================
   SEARCH TABLET
========================================================= */

@media (max-width: 1024px) {
  .reimii-search__results {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }
}

@media (max-width: 768px) {
  .reimii-search {
    padding: 2.75rem 1rem 4rem;
  }

  .reimii-search__header {
    margin-bottom: 2rem;
    padding: 2rem 1.5rem;
    border-radius: var(--r-radius);
  }

  .reimii-search__title {
    font-size: clamp(2rem, 9vw, 3rem);
  }

  .reimii-search__results {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .reimii-search-card__content {
    padding: 1rem;
  }

  .reimii-search-card__title {
    font-size: 0.95rem;
  }

  .reimii-search-empty,
  .reimii-search-start {
    padding: 2.5rem 1.5rem;
    border-radius: var(--r-radius);
  }
}

/* =========================================================
   SEARCH MOBILE
========================================================= */

@media (max-width: 480px) {
  .reimii-search {
    padding: 2rem 0.75rem 3rem;
  }

  .reimii-search__header {
    margin-bottom: 1.5rem;
    padding: 1.5rem 1rem;
    border-radius: 20px;
  }

  .reimii-search__eyebrow {
    margin-bottom: 0.75rem;
    font-size: 0.64rem;
  }

  .reimii-search__title {
    font-size: clamp(1.75rem, 10vw, 2.4rem);
  }

  .reimii-search__intro {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .reimii-search__form {
    margin-top: 1.5rem;
  }

  .reimii-search__field {
    flex-wrap: wrap;
    padding: 0.5rem;
    border-radius: 18px;
  }

  .reimii-search__icon {
    flex-basis: 40px;
    width: 40px;
    height: 46px;
  }

  .reimii-search__input {
    width: calc(100% - 48px);
    min-height: 46px;
    padding: 0;
    font-size: 16px;
  }

  .reimii-search__button {
    width: 100%;
    min-height: 46px;
  }

  .reimii-search__summary {
    margin-top: 1.25rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    border-radius: 14px;
  }

  .reimii-search__results {
    gap: 0.85rem;
  }

  .reimii-search-card {
    border-radius: 18px;
  }

  .reimii-search-card__type {
    top: 0.5rem;
    left: 0.5rem;
    min-height: 23px;
    padding: 0.25rem 0.5rem;
    font-size: 0.55rem;
  }

  .reimii-search-card__badge {
    top: 0.5rem;
    right: 0.5rem;
    min-height: 23px;
    padding: 0.25rem 0.5rem;
    font-size: 0.55rem;
  }

  .reimii-search-card__content {
    padding: 0.85rem;
  }

  .reimii-search-card__vendor {
    font-size: 0.58rem;
  }

  .reimii-search-card__title {
    margin-bottom: 0.55rem;
    font-size: 0.86rem;
    line-height: 1.25;
  }

  .reimii-search-card__current-price {
    font-size: 0.9rem;
  }

  .reimii-search-card__price-prefix,
  .reimii-search-card__compare-price {
    font-size: 0.68rem;
  }

  .reimii-search-card__excerpt {
    display: none;
  }

  .reimii-search-card__read-more {
    font-size: 0.72rem;
  }

  .reimii-search-empty,
  .reimii-search-start {
    padding: 2rem 1rem;
    border-radius: 18px;
  }

  .reimii-search-empty__icon,
  .reimii-search-start__icon {
    width: 70px;
    height: 70px;
    margin-bottom: 1.25rem;
    font-size: 2rem;
    border-radius: 22px;
  }

  .reimii-search-empty h2,
  .reimii-search-start h2 {
    font-size: 1.65rem;
  }

  .reimii-search-empty > p,
  .reimii-search-start > p {
    font-size: 0.9rem;
  }

  .reimii-search-empty__suggestions a,
  .reimii-search-start__links a {
    min-height: 34px;
    padding: 0.45rem 0.75rem;
    font-size: 0.72rem;
  }
}

@media (prefers-reduced-motion: reduce) {
  .reimii-search *,
  .reimii-search *::before,
  .reimii-search *::after {
    scroll-behavior: auto !important;
    transition: none !important;
    animation: none !important;
  }
}
