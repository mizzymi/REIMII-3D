<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no"
    >

    <title>
      {{ page_title }}
      {% unless page_title contains shop.name %}
        – {{ shop.name }}
      {% endunless %}
    </title>

    {% if settings.favicon != blank %}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
      <link
        rel="apple-touch-icon"
        href="{{ settings.favicon | image_url: width: 180, height: 180 }}"
      >
    {% endif %}

    {% if page_description %}
      <meta
        name="description"
        content="{{ page_description | escape }}"
      >
    {% endif %}

    <link rel="canonical" href="{{ canonical_url }}">

    {% liquid
      assign social_title = page_title | default: shop.name
      assign social_description = page_description | default: shop.description | strip_html
      assign social_image = settings.social_sharing_image

      if request.page_type == 'product' and product.featured_image
        assign social_image = product.featured_image
      elsif request.page_type == 'article' and article.image
        assign social_image = article.image
      elsif request.page_type == 'collection' and collection.image
        assign social_image = collection.image
      endif
    %}

    <meta property="og:site_name" content="{{ shop.name | escape }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ social_title | escape }}">
    <meta
      property="og:description"
      content="{{ social_description | escape }}"
    >
    <meta property="og:type" content="website">

    {% if request.page_type == 'product' %}
      <meta property="og:type" content="product">
    {% endif %}

    {% if social_image != blank %}
      <meta
        property="og:image"
        content="https:{{ social_image | image_url: width: 1200 }}"
      >
      <meta
        property="og:image:secure_url"
        content="https:{{ social_image | image_url: width: 1200 }}"
      >
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
      <meta
        property="og:image:alt"
        content="{{ social_title | escape }}"
      >
    {% endif %}

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ social_title | escape }}">
    <meta
      name="twitter:description"
      content="{{ social_description | escape }}"
    >

    {% if social_image != blank %}
      <meta
        name="twitter:image"
        content="https:{{ social_image | image_url: width: 1200 }}"
      >
    {% endif %}

    {{ content_for_header }}

    <!-- Tailwind compilado: no editar manualmente -->
    {{ 'application.css' | asset_url | stylesheet_tag }}

    <!-- Personalización visual de Reimii -->
    {{ 'reimii.css' | asset_url | stylesheet_tag }}

    <script
      src="{{ 'application.js' | asset_url }}"
      defer
    ></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>

  <body class="bg-reimii text-reimii">
    {% section 'header' %}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}
  </body>
</html>
