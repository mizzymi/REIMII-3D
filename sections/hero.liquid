<section
  class="hero"
  style="
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-min-height: {{ section.settings.desktop_height }}px;
    --hero-mobile-height: {{ section.settings.mobile_height }}px;
  "
>
  <div class="hero-media">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 2200
        | image_tag:
          class: 'hero-image hero-image-desktop',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 1800, 2200',
          sizes: '100vw',
          alt: section.settings.image.alt
        | default: section.settings.heading
      }}
    {% else %}
      <div class="hero-placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-image' }}
      </div>
    {% endif %}

    {% if section.settings.mobile_image != blank %}
      {{
        section.settings.mobile_image
        | image_url: width: 1000
        | image_tag:
          class: 'hero-image hero-image-mobile',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '375, 550, 750, 1000',
          sizes: '100vw',
          alt: section.settings.mobile_image.alt
        | default: section.settings.heading
      }}
    {% endif %}

    <div class="hero-overlay"></div>
  </div>

  <div class="hero-inner hero-align-{{ section.settings.content_alignment }}">
    <div class="hero-content">
      {% if section.settings.eyebrow != blank %}
        <p class="hero-eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="hero-heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="hero-text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank or section.settings.secondary_button_label != blank %}
        <div class="hero-actions">
          {% if section.settings.button_label != blank %}
            <a
              class="reimii-button hero-primary-button"
              {% if section.settings.button_link != blank %}
                href="{{ section.settings.button_link }}"
              {% else %}
                role="link"
                aria-disabled="true"
              {% endif %}
            >
              {{ section.settings.button_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_button_label != blank %}
            <a
              class="reimii-button reimii-button-secondary hero-secondary-button"
              {% if section.settings.secondary_button_link != blank %}
                href="{{ section.settings.secondary_button_link }}"
              {% else %}
                role="link"
                aria-disabled="true"
              {% endif %}
            >
              {{ section.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Bienvenido a Reimii"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Pequeños compañeros, grandes sonrisas"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Descripción",
      "default": "<p>Descubre figuras articuladas impresas en 3D, llenas de color y personalidad.</p>"
    },
    {
      "type": "header",
      "content": "Botones"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón principal",
      "default": "Ver la tienda"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón principal"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Texto del botón secundario",
      "default": "Explorar colecciones"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Enlace del botón secundario"
    },
    {
      "type": "header",
      "content": "Imágenes"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de escritorio"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Imagen para móvil"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Alineación del contenido",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Oscurecimiento de la imagen",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Altura en escritorio",
      "min": 420,
      "max": 850,
      "step": 10,
      "unit": "px",
      "default": 650
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Altura en móvil",
      "min": 420,
      "max": 750,
      "step": 10,
      "unit": "px",
      "default": 560
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
