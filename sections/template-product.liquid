{% assign current_variant = product.selected_or_first_available_variant %}

<section class="reimii-product">
  <div class="reimii-product__left">
    <div class="reimii-gallery">
      <button class="reimii-gallery-arrow prev" type="button">←</button>

      <div class="reimii-product__gallery" id="gallery">
        {% for image in product.images %}
          {{
            image
            | image_url: width: 1200
            | image_tag:
              class: 'reimii-product__image',
              loading: 'lazy',
              data-media-id: image.id,
              data-index: forloop.index0
          }}
        {% endfor %}
      </div>

      <button class="reimii-gallery-arrow next" type="button">→</button>
    </div>
    <div class="reimii-product__description-desktop">
      {{ product.description }}
    </div>
  </div>

  <div class="reimii-product__info">
    <p class="reimii-product__kicker">REIMII 3D Shop</p>
    <h1>{{ product.title }}</h1>

    <div class="reimii-product__trust">
      <span>Fabricado en España</span>
      <span>Impresión 3D premium</span>
      <span>Ideal para regalar</span>
      <span>Pago seguro</span>
    </div>

    <div class="reimii-product__price" data-product-price>
      {% if current_variant.compare_at_price > current_variant.price %}
        <span>{{ current_variant.price | money }}</span>
        <s>{{ current_variant.compare_at_price | money }}</s>
      {% else %}
        <span>{{ current_variant.price | money }}</span>
      {% endif %}
    </div>

    <div class="reimii-product__form" data-reimii-product-form>
      {% form 'product', product %}
        <input
          type="hidden"
          name="id"
          value="{{ current_variant.id }}"
          data-variant-id
          data-available="{{ current_variant.available }}"
        >

        {% unless product.has_only_default_variant %}
          <div class="reimii-variant-groups">
            {% for option in product.options_with_values %}
              <div class="reimii-option-group">
                <div class="reimii-option-header">
                  <span>{{ option.name }}</span>
                  <strong data-selected-option="{{ option.position }}">
                    {{ option.selected_value }}
                  </strong>
                </div>

                <div class="reimii-option-values">
                  {% for value in option.values %}
                    <button
                      type="button"
                      class="reimii-option {% if option.selected_value == value %}is-active{% endif %}"
                      data-option-position="{{ option.position }}"
                      data-option-value="{{ value | escape }}"
                    >
                      {{ value }}
                    </button>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% endunless %}

        <div class="reimii-product-quantity">
          <label
            for="ProductQuantity-{{ section.id }}"
            class="reimii-product-quantity__label"
          >
            Cantidad
          </label>

          <div class="reimii-quantity-selector">
            <button
              type="button"
              class="reimii-quantity-selector__button"
              data-quantity-minus
              aria-label="Reducir cantidad"
            >
              −
            </button>

            <input
              id="ProductQuantity-{{ section.id }}"
              class="reimii-quantity-selector__input"
              type="number"
              name="quantity"
              value="1"
              min="1"
              step="1"
              inputmode="numeric"
              data-quantity-input
            >

            <button
              type="button"
              class="reimii-quantity-selector__button"
              data-quantity-plus
              aria-label="Aumentar cantidad"
            >
              +
            </button>
          </div>
        </div>

        <button
          type="submit"
          class="reimii-product__submit"
          data-add-to-cart
          data-default-text="Añadir al carrito"
          {% unless product.selected_or_first_available_variant.available %}
            disabled
          {% endunless %}
        >
          <span data-add-to-cart-text>
            {% if product.selected_or_first_available_variant.available %}
              Añadir al carrito
            {% else %}
              Agotado
            {% endif %}
          </span>
        </button>

        <div
          class="reimii-shop-pay"
          data-shop-pay
          {% unless current_variant.available %}
            hidden
          {% endunless %}
        >
          {{ form | payment_button }}
        </div>

        <script type="application/json" data-product-json>
          {{ product.variants | json }}
        </script>
      {% endform %}
    </div>

    <div class="reimii-product__accordions">
      <details open>
        <summary>Producción y envío</summary>
        <p>
          Todos los productos se fabrican o preparan bajo pedido. El tiempo de producción habitual es de 1 a 6 días
          laborables, y el envío suele tardar entre 2 y 10 días laborables según destino y transportista.
        </p>
      </details>

      <details>
        <summary>Material</summary>
        <p>
          Fabricado mediante impresión 3D con materiales ligeros y resistentes, ideal para uso diario y coleccionismo.
        </p>
      </details>

      <details>
        <summary>Diseños y licencias</summary>
        <p>REIMII trabaja con diseños propios y modelos de artistas autorizados con derecho de venta.</p>
      </details>
    </div>
  </div>
  <div class="reimii-product__description-mobile">
    {{ product.description }}
  </div>
</section>

<div class="reimii-sticky-atc">
  <div>
    <strong>{{ product.title }}</strong>
    <span data-sticky-price>{{ current_variant.price | money }}</span>
  </div>

  {% form 'product', product, class: 'reimii-sticky-atc__form' %}
    <input
      type="hidden"
      name="id"
      value="{{ current_variant.id }}"
      data-sticky-variant-id
      data-available="{{ current_variant.available }}"
    >

    <input
      type="number"
      name="quantity"
      value="1"
      min="1"
      step="1"
      hidden
      data-sticky-quantity
    >

    <button
      type="submit"
      class="reimii-sticky-atc__button"
      data-add-to-cart
      data-default-text="Añadir al carrito"
      {% unless current_variant.available %}
        disabled
      {% endunless %}
    >
      <span data-add-to-cart-text>
        {% if current_variant.available %}
          Añadir al carrito
        {% else %}
          Agotado
        {% endif %}
      </span>
    </button>
  {% endform %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const gallery = document.querySelector('.reimii-product__gallery');
    const prevButton = document.querySelector('.reimii-gallery-arrow.prev');
    const nextButton = document.querySelector('.reimii-gallery-arrow.next');

    document.querySelectorAll('[data-reimii-product-form]').forEach((formWrapper) => {
      const productJson = formWrapper.querySelector('[data-product-json]');

      const variantInput = formWrapper.querySelector('[data-variant-id]');

      const optionButtons = formWrapper.querySelectorAll('[data-option-position]');

      const priceBox = document.querySelector('[data-product-price]');

      const stickyVariantInput = document.querySelector('[data-sticky-variant-id]');

      const stickyPrice = document.querySelector('[data-sticky-price]');

      const shopPay = formWrapper.querySelector('[data-shop-pay]');

      if (!productJson || !variantInput) return;

      let variants = [];

      try {
        variants = JSON.parse(productJson.textContent);
      } catch (error) {
        console.error('No se pudieron cargar las variantes.', error);
        return;
      }

      const selectedOptions = {};

      const formatMoney = (cents) => {
        return new Intl.NumberFormat('es-ES', {
          style: 'currency',
          currency: '{{ cart.currency.iso_code }}',
        }).format(cents / 100);
      };

      const updatePrice = (variant) => {
        if (priceBox) {
          if (variant.compare_at_price && variant.compare_at_price > variant.price) {
            priceBox.innerHTML = `
                <span>${formatMoney(variant.price)}</span>
                <s>${formatMoney(variant.compare_at_price)}</s>
              `;
          } else {
            priceBox.innerHTML = `
                <span>${formatMoney(variant.price)}</span>
              `;
          }
        }

        if (stickyPrice) {
          stickyPrice.textContent = formatMoney(variant.price);
        }
      };

      const updateVariantImage = (variant) => {
        if (!gallery || !variant.featured_image) return;

        const mediaId = variant.featured_image.id;

        const image = gallery.querySelector(`[data-media-id="${mediaId}"]`);

        if (!image) return;

        gallery.scrollTo({
          left: image.offsetLeft,
          behavior: 'smooth',
        });
      };

      const updateVariantInputs = (variant) => {
        const available = String(variant.available);

        variantInput.value = variant.id;
        variantInput.dataset.available = available;

        if (stickyVariantInput) {
          stickyVariantInput.value = variant.id;
          stickyVariantInput.dataset.available = available;
        }

        /*
         * Los cambios de value hechos por JavaScript no siempre
         * activan los observadores, por eso disparamos change.
         */
        variantInput.dispatchEvent(
          new Event('change', {
            bubbles: true,
          })
        );

        if (stickyVariantInput) {
          stickyVariantInput.dispatchEvent(
            new Event('change', {
              bubbles: true,
            })
          );
        }
      };

      const updatePaymentButton = (variant) => {
        if (!shopPay) return;

        shopPay.hidden = !variant.available;
      };

      const selectVariant = () => {
        const matchedVariant = variants.find((variant) => {
          return variant.options.every((optionValue, index) => {
            return selectedOptions[index + 1] === optionValue;
          });
        });

        if (!matchedVariant) return;

        updateVariantInputs(matchedVariant);
        updatePrice(matchedVariant);
        updateVariantImage(matchedVariant);
        updatePaymentButton(matchedVariant);

        document.dispatchEvent(
          new CustomEvent('reimii:variant-changed', {
            detail: {
              variant: matchedVariant,
            },
          })
        );
      };

      optionButtons.forEach((button) => {
        if (button.classList.contains('is-active')) {
          selectedOptions[button.dataset.optionPosition] = button.dataset.optionValue;
        }

        button.addEventListener('click', () => {
          const position = button.dataset.optionPosition;

          const value = button.dataset.optionValue;

          selectedOptions[position] = value;

          formWrapper.querySelectorAll(`[data-option-position="${position}"]`).forEach((optionButton) => {
            optionButton.classList.remove('is-active');
          });

          button.classList.add('is-active');

          const selectedLabel = formWrapper.querySelector(`[data-selected-option="${position}"]`);

          if (selectedLabel) {
            selectedLabel.textContent = value;
          }

          selectVariant();
        });
      });

      /*
       * Garantiza que el botón Comprar ahora tenga
       * el estado correcto al cargar.
       */
      const initialVariant = variants.find((variant) => String(variant.id) === String(variantInput.value));

      if (initialVariant) {
        variantInput.dataset.available = String(initialVariant.available);

        if (stickyVariantInput) {
          stickyVariantInput.value = initialVariant.id;
          stickyVariantInput.dataset.available = String(initialVariant.available);
        }

        updatePaymentButton(initialVariant);
      }
    });

    // GALERÍA CON FLECHAS
    if (gallery && prevButton && nextButton) {
      const getSlideWidth = () => {
        const slide = gallery.querySelector('.reimii-product__image');

        if (!slide) return gallery.clientWidth;

        const styles = getComputedStyle(gallery);
        const gap = Number.parseInt(styles.gap || '0', 10);

        return slide.getBoundingClientRect().width + (Number.isFinite(gap) ? gap : 0);
      };

      nextButton.addEventListener('click', () => {
        gallery.scrollBy({
          left: getSlideWidth(),
          behavior: 'smooth',
        });
      });

      prevButton.addEventListener('click', () => {
        gallery.scrollBy({
          left: -getSlideWidth(),
          behavior: 'smooth',
        });
      });
    }
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('shopify-section-{{ section.id }}');

    if (!section) return;

    const productForms = section.querySelectorAll('form[action*="/cart/add"]');

    const quantityInput = section.querySelector('[data-quantity-input]');

    const stickyQuantityInputs = section.querySelectorAll('[data-sticky-quantity]');

    const minusButton = section.querySelector('[data-quantity-minus]');

    const plusButton = section.querySelector('[data-quantity-plus]');

    let cartVariantIds = new Set();

    const normalizeQuantity = (value) => {
      const quantity = Number.parseInt(value, 10);

      if (!Number.isFinite(quantity) || quantity < 1) {
        return 1;
      }

      return quantity;
    };

    const syncQuantity = () => {
      if (!quantityInput) return;

      const quantity = normalizeQuantity(quantityInput.value);

      quantityInput.value = quantity;

      stickyQuantityInputs.forEach((input) => {
        input.value = quantity;
      });
    };

    const getVariantInput = (form) => {
      return form.querySelector('[name="id"]');
    };

    const getVariantId = (form) => {
      const variantInput = getVariantInput(form);

      return variantInput ? String(variantInput.value) : null;
    };

    const variantIsAvailable = (form) => {
      const variantInput = getVariantInput(form);

      return variantInput?.dataset.available === 'true';
    };

    const getButton = (form) => {
      return form.querySelector('[data-add-to-cart]');
    };

    const setButtonText = (button, text) => {
      if (!button) return;

      const textElement = button.querySelector('[data-add-to-cart-text]');

      if (textElement) {
        textElement.textContent = text;
      } else {
        button.textContent = text;
      }
    };

    const variantIsInCart = (variantId) => {
      return variantId && cartVariantIds.has(String(variantId));
    };

    const updateButtonForForm = (form) => {
      const button = getButton(form);

      if (!button || button.dataset.loading === 'true') {
        return;
      }

      const variantId = getVariantId(form);
      const available = variantIsAvailable(form);

      if (!available) {
        button.disabled = true;
        button.removeAttribute('aria-busy');
        setButtonText(button, 'Agotado');
        return;
      }

      button.disabled = false;
      button.removeAttribute('aria-busy');

      setButtonText(
        button,
        variantIsInCart(variantId) ? 'Añadir más' : button.dataset.defaultText || 'Añadir al carrito'
      );
    };

    const updateAllButtons = () => {
      productForms.forEach((form) => {
        updateButtonForForm(form);
      });
    };

    const updateVisibleCartCounters = (cart) => {
      const itemCount = Number(cart.item_count) || 0;

      const visibleCount = itemCount > 9 ? '+9' : String(itemCount);

      document.querySelectorAll('[data-cart-count]').forEach((counter) => {
        counter.textContent = visibleCount;
        counter.hidden = itemCount === 0;
      });

      document.querySelectorAll('.reimii-header-cart').forEach((cartLink) => {
        cartLink.setAttribute('aria-label', `Carrito, ${itemCount} ${itemCount === 1 ? 'artículo' : 'artículos'}`);
      });
    };

    const loadCart = async () => {
      const response = await fetch(`${window.Shopify.routes.root}cart.js`, {
        headers: {
          Accept: 'application/json',
        },
      });

      if (!response.ok) {
        throw new Error('No se pudo consultar el carrito.');
      }

      const cart = await response.json();

      cartVariantIds = new Set(cart.items.map((item) => String(item.variant_id)));

      updateVisibleCartCounters(cart);
      updateAllButtons();

      document.dispatchEvent(
        new CustomEvent('reimii:cart-updated', {
          detail: {
            cart,
          },
        })
      );

      return cart;
    };

    minusButton?.addEventListener('click', () => {
      if (!quantityInput) return;

      quantityInput.value = Math.max(1, normalizeQuantity(quantityInput.value) - 1);

      syncQuantity();
    });

    plusButton?.addEventListener('click', () => {
      if (!quantityInput) return;

      quantityInput.value = normalizeQuantity(quantityInput.value) + 1;

      syncQuantity();
    });

    quantityInput?.addEventListener('change', syncQuantity);

    quantityInput?.addEventListener('input', syncQuantity);

    productForms.forEach((form) => {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const button = getButton(form);

        if (!button || button.dataset.loading === 'true') {
          return;
        }

        if (!variantIsAvailable(form)) {
          button.disabled = true;
          setButtonText(button, 'Agotado');
          return;
        }

        syncQuantity();

        button.dataset.loading = 'true';
        button.disabled = true;
        button.setAttribute('aria-busy', 'true');

        setButtonText(button, 'Añadiendo…');

        try {
          const formData = new FormData(form);

          const response = await fetch(`${window.Shopify.routes.root}cart/add.js`, {
            method: 'POST',
            headers: {
              Accept: 'application/json',
            },
            body: formData,
          });

          const result = await response.json();

          if (!response.ok) {
            throw new Error(result.description || result.message || 'No se pudo añadir el producto.');
          }

          setButtonText(button, '✓ Añadido');

          await loadCart();

          window.setTimeout(() => {
            button.dataset.loading = 'false';
            button.removeAttribute('aria-busy');

            updateButtonForForm(form);
          }, 1000);
        } catch (error) {
          console.error(error);

          button.dataset.loading = 'false';
          button.removeAttribute('aria-busy');

          if (!variantIsAvailable(form)) {
            button.disabled = true;
            setButtonText(button, 'Agotado');
            return;
          }

          button.disabled = false;
          setButtonText(button, 'Inténtalo de nuevo');

          window.setTimeout(() => {
            updateButtonForForm(form);
          }, 2000);
        }
      });

      const variantInput = getVariantInput(form);

      if (variantInput) {
        variantInput.addEventListener('change', () => {
          updateAllButtons();
        });

        new MutationObserver(() => {
          updateAllButtons();
        }).observe(variantInput, {
          attributes: true,
          attributeFilter: ['value', 'data-available'],
        });
      }
    });

    document.addEventListener('reimii:variant-changed', () => {
      updateAllButtons();
    });

    syncQuantity();

    loadCart().catch((error) => {
      console.warn(error);
      updateAllButtons();
    });

    document.addEventListener('reimii:refresh-cart-buttons', () => {
      loadCart().catch(console.warn);
    });
  });
</script>

{% schema %}
{
  "name": "Product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
