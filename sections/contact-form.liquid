<section class="contact-section">
  <div class="contact-container">
    <header class="contact-header">
      {% if section.settings.eyebrow != blank %}
        <p class="contact-eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="contact-title">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="contact-description">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </header>

    <div
      class="
        contact-layout
        {% if section.settings.image == blank %}
          contact-layout-full
        {% endif %}
      "
    >
      {% if section.settings.image != blank %}
        <div class="contact-media">
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              class: 'contact-image',
              loading: 'lazy',
              widths: '480, 720, 960, 1200, 1400',
              sizes: '(max-width: 768px) 100vw, 45vw',
              alt: section.settings.image.alt
            | default: section.settings.heading
          }}

          {% if section.settings.image_text != blank %}
            <div class="contact-media-content">
              {{ section.settings.image_text }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="contact-panel">
        {% if section.settings.form_heading != blank %}
          <h3 class="contact-form-title">
            {{ section.settings.form_heading }}
          </h3>
        {% endif %}

        {% if section.settings.form_text != blank %}
          <div class="contact-form-intro">
            {{ section.settings.form_text }}
          </div>
        {% endif %}

        {% form 'contact', class: 'contact-form' %}
          {% if form.posted_successfully? %}
            <div
              class="contact-message contact-message-success"
              tabindex="-1"
              autofocus
            >
              <strong>
                {{ section.settings.success_heading }}
              </strong>

              <p>
                {{ section.settings.success_message }}
              </p>
            </div>
          {% endif %}

          {% if form.errors %}
            <div
              class="contact-message contact-message-error"
              role="alert"
              tabindex="-1"
              autofocus
            >
              <strong> No hemos podido enviar el formulario. </strong>

              <ul class="contact-error-list">
                {% for field in form.errors %}
                  <li>
                    {% if field == 'form' %}
                      {{ form.errors.messages[field] }}
                    {% else %}
                      <a href="#ContactForm-{{ field }}-{{ section.id }}">
                        {{ form.errors.translated_fields[field] | capitalize }}
                        {{ form.errors.messages[field] }}
                      </a>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          <div class="contact-fields">
            <div class="contact-field">
              <label
                for="ContactForm-name-{{ section.id }}"
                class="contact-label"
              >
                {{ section.settings.name_label }}
              </label>

              <input
                id="ContactForm-name-{{ section.id }}"
                class="contact-input"
                type="text"
                name="contact[name]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                autocomplete="name"
                placeholder="{{ section.settings.name_placeholder }}"
              >
            </div>

            <div class="contact-field">
              <label
                for="ContactForm-email-{{ section.id }}"
                class="contact-label"
              >
                {{ section.settings.email_label }}
                <span aria-hidden="true">*</span>
              </label>

              <input
                id="ContactForm-email-{{ section.id }}"
                class="contact-input"
                type="email"
                name="contact[email]"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                spellcheck="false"
                placeholder="{{ section.settings.email_placeholder }}"
                required
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="ContactForm-email-error-{{ section.id }}"
                {% endif %}
              >

              {% if form.errors contains 'email' %}
                <small
                  id="ContactForm-email-error-{{ section.id }}"
                  class="contact-field-error"
                >
                  {{ form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email }}
                </small>
              {% endif %}
            </div>

            {% if section.settings.show_phone %}
              <div class="contact-field">
                <label
                  for="ContactForm-phone-{{ section.id }}"
                  class="contact-label"
                >
                  {{ section.settings.phone_label }}
                </label>

                <input
                  id="ContactForm-phone-{{ section.id }}"
                  class="contact-input"
                  type="tel"
                  name="contact[phone]"
                  value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
                  autocomplete="tel"
                  pattern="[0-9+\-\s().]*"
                  placeholder="{{ section.settings.phone_placeholder }}"
                >
              </div>
            {% endif %}

            {% if section.settings.show_subject %}
              <div class="contact-field">
                <label
                  for="ContactForm-subject-{{ section.id }}"
                  class="contact-label"
                >
                  {{ section.settings.subject_label }}
                </label>

                <input
                  id="ContactForm-subject-{{ section.id }}"
                  class="contact-input"
                  type="text"
                  name="contact[subject]"
                  value="{{ form.subject }}"
                  placeholder="{{ section.settings.subject_placeholder }}"
                >
              </div>
            {% endif %}

            <div class="contact-field contact-field-full">
              <label
                for="ContactForm-body-{{ section.id }}"
                class="contact-label"
              >
                {{ section.settings.message_label }}
                <span aria-hidden="true">*</span>
              </label>

              <textarea
                id="ContactForm-body-{{ section.id }}"
                class="contact-textarea"
                name="contact[body]"
                rows="8"
                placeholder="{{ section.settings.message_placeholder }}"
                required
              >{{ form.body }}</textarea>
            </div>
          </div>

          {% if section.settings.show_privacy_text and section.settings.privacy_text != blank %}
            <div class="contact-privacy">
              {{ section.settings.privacy_text }}
            </div>
          {% endif %}

          <button
            type="submit"
            class="reimii-button contact-submit"
          >
            {{ section.settings.button_label }}
          </button>
        {% endform %}

        {% if section.blocks.size > 0 %}
          <div class="contact-details">
            {% for block in section.blocks %}
              <div
                class="contact-detail"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.heading != blank %}
                  <h3 class="contact-detail-title">
                    {{ block.settings.heading }}
                  </h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="contact-detail-text">
                    {{ block.settings.text }}
                  </div>
                {% endif %}

                {% if block.settings.link_label != blank %}
                  <a
                    href="{{ block.settings.link }}"
                    class="contact-detail-link"
                  >
                    {{ block.settings.link_label }}
                  </a>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Formulario de contacto",
  "tag": "section",
  "class": "section-contact-form",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Cabecera"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Estamos aqui para ayudarte"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Contacta con Reimii"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descripción",
      "default": "<p>¿Tienes alguna pregunta sobre nuestros productos o sobre tu pedido? Escríbenos y te responderemos lo antes posible.</p>"
    },
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "richtext",
      "id": "image_text",
      "label": "Texto sobre la imagen"
    },
    {
      "type": "header",
      "content": "Formulario"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Título del formulario",
      "default": "¿En qué podemos ayudarte?"
    },
    {
      "type": "richtext",
      "id": "form_text",
      "label": "Texto del formulario",
      "default": "<p>Completa el formulario y cuéntanos todos los detalles.</p>"
    },
    {
      "type": "text",
      "id": "name_label",
      "label": "Etiqueta del nombre",
      "default": "Nombre"
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Texto del campo de nombre",
      "default": "Tu nombre"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Etiqueta del correo",
      "default": "Correo electrónico"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Texto del campo de correo",
      "default": "tu@email.com"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Mostrar teléfono",
      "default": false
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Etiqueta del teléfono",
      "default": "Teléfono"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Texto del campo de teléfono",
      "default": "Tu teléfono"
    },
    {
      "type": "checkbox",
      "id": "show_subject",
      "label": "Mostrar asunto",
      "default": true
    },
    {
      "type": "text",
      "id": "subject_label",
      "label": "Etiqueta del asunto",
      "default": "Asunto"
    },
    {
      "type": "text",
      "id": "subject_placeholder",
      "label": "Texto del campo de asunto",
      "default": "¿Sobre qué quieres escribirnos?"
    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Etiqueta del mensaje",
      "default": "Mensaje"
    },
    {
      "type": "text",
      "id": "message_placeholder",
      "label": "Texto del campo de mensaje",
      "default": "Cuéntanos cómo podemos ayudarte..."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Enviar mensaje"
    },
    {
      "type": "header",
      "content": "Privacidad"
    },
    {
      "type": "checkbox",
      "id": "show_privacy_text",
      "label": "Mostrar texto de privacidad",
      "default": true
    },
    {
      "type": "richtext",
      "id": "privacy_text",
      "label": "Texto de privacidad",
      "default": "<p>Utilizaremos tus datos únicamente para responder a tu consulta.</p>"
    },
    {
      "type": "header",
      "content": "Confirmación"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Título de confirmación",
      "default": "¡Mensaje enviado!"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Mensaje de confirmación",
      "default": "Gracias por contactar con Reimii. Te responderemos lo antes posible."
    }
  ],
  "blocks": [
    {
      "type": "contact_detail",
      "name": "Dato de contacto",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título",
          "default": "Correo"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Texto",
          "default": "<p>Escríbenos para cualquier consulta.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Texto del enlace"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Formulario de contacto",
      "blocks": [
        {
          "type": "contact_detail",
          "settings": {
            "heading": "Correo",
            "text": "<p>Escríbenos para cualquier consulta.</p>"
          }
        },
        {
          "type": "contact_detail",
          "settings": {
            "heading": "Horario",
            "text": "<p>Respondemos de lunes a viernes.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
