{% assign main_manu_linklist = linklists[section.settings.main_menu] %}

<div class="relative bg-reimii-black" x-data="{ mobileMenuOpen: false }">
  <div class="mx-auto p-4 sm:px-6">
    <div class="flex justify-between md:hidden">
      <div class="flex justify-start min-w-0">
        <a href="{{ routes.root_url }}" class="inline-flex items-center">
          {% if section.settings.logo != blank %}
            {{
              section.settings.logo
              | image_url: width: section.settings.logo_width
              | image_tag: alt: shop.name, width: section.settings.logo_width, class: 'logo h-auto'
            }}
          {% else %}
            <span class="text-reimii-white text-xl font-reimii-display">
              {{
                shop.name
                | replace: 'á', 'a'
                | replace: 'é', 'e'
                | replace: 'í', 'i'
                | replace: 'ó', 'o'
                | replace: 'ú', 'u'
                | replace: 'Á', 'A'
                | replace: 'É', 'E'
                | replace: 'Í', 'I'
                | replace: 'Ó', 'O'
                | replace: 'Ú', 'U'
                | replace: 'ñ', 'n'
                | replace: 'Ñ', 'N'
              }}
            </span>
          {% endif %}
        </a>
      </div>

      <!-- MOBILE MENU BUTTON -->
      <div class="-mr-2 -my-2 ml-3">
        <div class="flex items-center justify-end">
          <a
            href="{{ routes.cart_url }}"
            class="reimii-header-cart whitespace-nowrap text-reimii-white hover:text-reimii-pink"
            aria-label="Carrito, {{ cart.item_count }} artículos"
          >
            {% if section.settings.cart_icon != blank %}
              {{
                section.settings.cart_icon
                | image_url: width: section.settings.cart_icon_width
                | image_tag: alt: 'Carrito', width: section.settings.cart_icon_width, class: 'h-auto'
              }}
            {% else %}
              {% render 'icons-shopping-cart' %}
            {% endif %}
            <span
              class="reimii-header-cart__count"
              data-cart-count
              {% if cart.item_count == 0 %}
                hidden
              {% endif %}
              aria-hidden="true"
            >
              {% if cart.item_count > 9 %}
                +9
              {% else %}
                {{ cart.item_count }}
              {% endif %}
            </span>
          </a>
          <button
            type="button"
            class="p-2 inline-flex items-center justify-center focus:outline-none"
            x-on:click="mobileMenuOpen = !mobileMenuOpen"
            aria-label="Abrir menú"
            :aria-expanded="mobileMenuOpen"
          >
            {% if section.settings.hamburger_icon != blank %}
              {{
                section.settings.hamburger_icon
                | image_url: width: section.settings.hamburger_width
                | image_tag: alt: 'Abrir menu', width: section.settings.hamburger_width, class: 'h-auto'
              }}
            {% else %}
              {% assign hamburger_icon_id = section.id | append: '-hamburger' %}

              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 64 64"
                width="{{ section.settings.hamburger_width | default: 36 }}"
                height="{{ section.settings.hamburger_width | default: 36 }}"
                role="img"
                aria-label="Abrir menu"
                class="icon"
              >
                <defs>
                  <linearGradient
                    id="reimii-hamburger-gradient-{{ hamburger_icon_id }}"
                    x1="10"
                    y1="32"
                    x2="54"
                    y2="32"
                    gradientUnits="userSpaceOnUse"
                  >
                    <stop offset="0%" stop-color="#8e73d8" />
                    <stop offset="100%" stop-color="#f7a9d4" />
                  </linearGradient>
                </defs>

                <path
                  d="M12 18.5
                     C21 18.1 29 18.8 37 18.4
                     C43 18.1 49 18.4 52 18.2"
                  fill="none"
                  stroke="url(#reimii-hamburger-gradient-{{ hamburger_icon_id }})"
                  stroke-width="3.05"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />

                <path
                  d="M12 32
                     C21 31.6 29 32.4 37 32
                     C43 31.7 49 32.2 52 31.9"
                  fill="none"
                  stroke="url(#reimii-hamburger-gradient-{{ hamburger_icon_id }})"
                  stroke-width="3.05"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />

                <path
                  d="M12 45.5
                     C21 45.1 29 45.8 37 45.4
                     C43 45.1 49 45.5 52 45.2"
                  fill="none"
                  stroke="url(#reimii-hamburger-gradient-{{ hamburger_icon_id }})"
                  stroke-width="3.05"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            {% endif %}
          </button>
        </div>
      </div>

      <!-- MOBILE MENU -->
      <div
        class="absolute z-50 top-0 inset-x-0 p-2 transform origin-top-left md:hidden"
        x-show="mobileMenuOpen"
        x-cloak
        @click.away="mobileMenuOpen = false"
        @keydown.escape.window="mobileMenuOpen = false"
      >
        <div class="shadow-lg rounded-lg ring-1 ring-black ring-opacity-5 bg-reimii-white w-full">
          <div class="p-5 divide-y-2 divide-gray-50">
            <!-- MOBILE MENU HEADER -->
            <div class="flex items-center justify-between pb-3">
              <div>
                {% if section.settings.mobile_logo != blank %}
                  {{
                    section.settings.mobile_logo
                    | image_url: width: section.settings.mobile_logo_width
                    | image_tag: alt: shop.name, width: section.settings.mobile_logo_width, class: 'h-auto'
                  }}
                {% else %}
                  <h1 class="text-lg text-reimii">
                    {{ shop.name }}
                  </h1>
                {% endif %}
              </div>

              <div class="-mr-2">
                <button
                  type="button"
                  class="rounded-md p-2 text-reimii"
                  x-on:click="mobileMenuOpen = false"
                  aria-label="Cerrar menú"
                >
                  {% if section.settings.close_icon != blank %}
                    {{
                      section.settings.close_icon
                      | image_url: width: section.settings.close_icon_width
                      | image_tag: alt: 'Cerrar menú', width: section.settings.close_icon_width, class: 'h-auto'
                    }}
                  {% else %}
                    {% render 'icons-close' %}
                  {% endif %}
                </button>
              </div>
            </div>

            <!-- MOBILE NAVIGATION -->
            <div class="pt-3">
              <nav class="grid gap-y-7">
                {% for link in main_manu_linklist.links %}
                  {% if link.links != blank %}
                    <div
                      class="relative"
                      x-data="{ submenuOpen: false }"
                    >
                      <button
                        type="button"
                        class="p-3 flex justify-between w-full rounded-md text-reimii hover:text-reimii-pink-dark hover:bg-reimii-pink-soft"
                        x-on:click="submenuOpen = !submenuOpen"
                        :aria-expanded="submenuOpen"
                      >
                        <span>{{ link.title }}</span>

                        <span
                          class="transition-transform duration-200"
                          :class="{ 'rotate-180': submenuOpen }"
                        >
                          {% if section.settings.dropdown_icon != blank %}
                            {{
                              section.settings.dropdown_icon
                              | image_url: width: section.settings.dropdown_icon_width
                              | image_tag: alt: '', width: section.settings.dropdown_icon_width, class: 'h-auto'
                            }}
                          {% else %}
                            {% render 'icons-dropdown' %}
                          {% endif %}
                        </span>
                      </button>

                      <div
                        class="grid gap-y-3 pt-3"
                        x-show="submenuOpen"
                        x-collapse
                      >
                        {% for sublink in link.links %}
                          <a
                            href="{{ sublink.url }}"
                            class="p-3 mx-3 flex items-center rounded-md text-reimii hover:text-reimii-pink-dark hover:bg-reimii-pink-soft"
                          >
                            {{ sublink.title }}
                          </a>
                        {% endfor %}
                      </div>
                    </div>

                  {% else %}
                    <a
                      href="{{ link.url }}"
                      class="p-3 flex items-center rounded-md text-reimii hover:text-reimii-pink-dark hover:bg-reimii-pink-soft"
                    >
                      {{ link.title }}
                    </a>
                  {% endif %}
                {% endfor %}
              </nav>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="hidden md:grid md:grid-cols-[1fr_auto_1fr] items-center gap-8 w-full">
      <!-- LOGO -->
      <div class="flex justify-start min-w-0">
        <a href="{{ routes.root_url }}" class="inline-flex items-center">
          {% if section.settings.logo != blank %}
            {{
              section.settings.logo
              | image_url: width: section.settings.logo_width
              | image_tag: alt: shop.name, width: section.settings.logo_width, class: 'logo h-auto'
            }}
          {% else %}
            <span class="text-reimii-white text-xl font-reimii-display">
              {{ shop.name }}
            </span>
          {% endif %}
        </a>
      </div>

      <!-- DESKTOP NAVIGATION -->
      <nav class="flex justify-center items-center space-x-10 whitespace-nowrap">
        {% for link in main_manu_linklist.links %}
          {% if link.links != blank %}
            <div
              class="relative"
              x-data="{ open: false }"
            >
              <button
                x-on:click="open = !open"
                type="button"
                class="flex items-center gap-2 text-reimii-white hover:text-reimii-pink"
                :aria-expanded="open"
              >
                <span>{{ link.title }}</span>

                <span
                  class="transition-transform duration-200"
                  :class="{ 'rotate-180': open }"
                >
                  {% if section.settings.dropdown_icon_on_dark != blank %}
                    {{
                      section.settings.dropdown_icon
                      | image_url: width: section.settings.dropdown_icon_width
                      | image_tag: alt: '', width: section.settings.dropdown_icon_width, class: 'h-auto'
                    }}
                  {% else %}
                    {% render 'icons-dropdown-on-dark' %}
                  {% endif %}
                </span>
              </button>

              <div
                x-show="open"
                x-cloak
                @click.away="open = false"
                @keydown.escape.window="open = false"
                class="absolute z-50 -ml-5 mt-4 transform px-2 w-screen max-w-md sm:px-0 lg:ml-0 lg:left-1/2 lg:-translate-x-1/2"
              >
                <div class="shadow-lg border ring-black ring-opacity-5 overflow-hidden rounded-lg">
                  <div class="relative grid gap-6 bg-reimii-white px-5 py-6 sm:gap-8 sm:p-8">
                    {% for sublink in link.links %}
                      <a
                        href="{{ sublink.url }}"
                        class="-m-3 p-3 flex items-start rounded-lg hover:bg-reimii-pink-soft text-reimii hover:text-reimii-pink-dark"
                      >
                        <div class="ml-4">
                          <p class="font-reimii font-medium">
                            {{ sublink.title }}
                          </p>
                        </div>
                      </a>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>

          {% else %}
            <div class="relative">
              <a
                href="{{ link.url }}"
                class="text-reimii-white hover:text-reimii-pink"
              >
                {{ link.title }}
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </nav>

      <!-- DESKTOP ACTIONS -->
      <div class="flex justify-end items-center space-x-5">
        <a
          href="{{ routes.cart_url }}"
          class="reimii-header-cart whitespace-nowrap text-reimii-white hover:text-reimii-pink"
          aria-label="Carrito"
        >
          {% if section.settings.cart_icon != blank %}
            {{
              section.settings.cart_icon
              | image_url: width: section.settings.cart_icon_width
              | image_tag: alt: 'Carrito', width: section.settings.cart_icon_width, class: 'h-auto'
            }}
          {% else %}
            {% render 'icons-shopping-cart' %}
          {% endif %}
          <span
            class="reimii-header-cart__count"
            data-cart-count
            {% if cart.item_count == 0 %}
              hidden
            {% endif %}
            aria-hidden="true"
          >
            {% if cart.item_count > 9 %}
              +9
            {% else %}
              {{ cart.item_count }}
            {% endif %}
          </span>
        </a>
        {% if shop.customer_accounts_enabled %}
          <a
            href="{{ routes.account_login_url }}"
            class="text-reimii-white hover:text-reimii-pink"
          >
            Login
          </a>

          <a
            href="{{ routes.account_register_url }}"
            class="text-reimii-white hover:text-reimii-pink"
          >
            Register
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Header Navigation",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo principal"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Ancho del logo",
      "min": 80,
      "max": 300,
      "step": 5,
      "unit": "px",
      "default": 180
    },
    {
      "type": "image_picker",
      "id": "mobile_logo",
      "label": "Logo del menú móvil"
    },
    {
      "type": "range",
      "id": "mobile_logo_width",
      "label": "Ancho del logo móvil",
      "min": 60,
      "max": 240,
      "step": 5,
      "unit": "px",
      "default": 140
    },
    {
      "type": "header",
      "content": "Menu"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Menú principal",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Iconos"
    },
    {
      "type": "image_picker",
      "id": "hamburger_icon",
      "label": "Icono hamburguesa"
    },
    {
      "type": "range",
      "id": "hamburger_width",
      "label": "Tamaño del icono hamburguesa",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "image_picker",
      "id": "close_icon",
      "label": "Icono de cerrar"
    },
    {
      "type": "range",
      "id": "close_icon_width",
      "label": "Tamaño del icono de cerrar",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "image_picker",
      "id": "dropdown_icon",
      "label": "Icono desplegable"
    },
    {
      "type": "image_picker",
      "id": "dropdown_icon_on_dark",
      "label": "Icono desplegable en zona oscura"
    },
    {
      "type": "range",
      "id": "dropdown_icon_width",
      "label": "Tamaño del icono desplegable",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "image_picker",
      "id": "cart_icon",
      "label": "Icono del carrito"
    },
    {
      "type": "range",
      "id": "cart_icon_width",
      "label": "Tamaño del icono del carrito",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 30
    }
  ]
}
{% endschema %}
