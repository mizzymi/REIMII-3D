<section class="shop-benefits">
  <div class="shop-benefits-container">
    {% if section.settings.heading != blank %}
      <h2 class="shop-benefits-title">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="shop-benefits-grid">
      {% for block in section.blocks %}
        <article class="shop-benefit" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <img
              src="{{ block.settings.icon | image_url: width: 80 }}"
              alt="{{ block.settings.title }}"
              width="48"
              height="48"
              class="shop-benefit-icon"
            >
          {% endif %}

          <h3>
            {{ block.settings.title }}
          </h3>

          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop Benefits",
  "tag": "section",
  "class": "section-shop-benefits",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Por qué elegir Reimii?"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icono"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Alta calidad"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción",
          "default": "Cada figura está impresa en 3D con materiales de alta calidad."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Impresión 3D Premium",
            "text": "Fabricado con materiales de alta calidad para durar."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Diseños Exclusivos",
            "text": "Personajes únicos llenos de personalidad."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Envío Seguro",
            "text": "Empaquetado cuidadosamente para que llegue perfecto."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Hecho con Amor",
            "text": "Cada pedido se prepara con mimo desde nuestro estudio."
          }
        }
      ]
    }
  ]
}
{% endschema %}
