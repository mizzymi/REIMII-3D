<section class="brand-story">
  <div class="brand-story-container">
    <div class="brand-story-media">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            class: 'brand-story-image',
            loading: 'lazy',
            widths: '480, 720, 960, 1200',
            sizes: '(max-width:768px) 100vw, 50vw',
            alt: section.settings.heading
        }}
      {% endif %}
    </div>

    <div class="brand-story-content">
      {% if section.settings.eyebrow != blank %}
        <span class="brand-story-eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      <h2 class="brand-story-title">
        {{ section.settings.heading }}
      </h2>

      <div class="brand-story-text">
        {{ section.settings.text }}
      </div>

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="reimii-button"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "section-brand-story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Nuestra historia"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Cada personaje comienza con una idea."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>En Reimii diseñamos y fabricamos figuras articuladas impresas en 3D llenas de personalidad. Cada creación nace con el objetivo de sacar una sonrisa y convertirse en un pequeño compañero para el día a día.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Botón",
      "default": "Conoce Reimii"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}
