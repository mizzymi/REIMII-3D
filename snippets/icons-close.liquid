{% assign icon_id = 'now' | date: '%N' %}

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="url(#reimii-gradient-{{ icon_id }})"
  stroke-width="2.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="icon"
  aria-hidden="true"
>
  <defs>
    <linearGradient
      id="reimii-gradient-{{ icon_id }}"
      x1="2"
      y1="2"
      x2="22"
      y2="22"
      gradientUnits="userSpaceOnUse"
    >
      <stop offset="0%" stop-color="#8e73d8" />
      <stop offset="100%" stop-color="#f7a9d4" />
    </linearGradient>
  </defs>

  <path d="M6 6L18 18" />
  <path d="M18 6L6 18" />
</svg>