{% assign icon_id = 'now' | date: '%N' %}

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="url(#reimii-gradient-{{ icon_id }})"
  stroke-width="2.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="icon"
  aria-hidden="true"
>
  <defs>
    <linearGradient
      id="reimii-gradient-{{ icon_id }}"
      x1="2"
      y1="12"
      x2="22"
      y2="12"
      gradientUnits="userSpaceOnUse"
    >
      <stop offset="0%" stop-color="#fdd7ec" />
      <stop offset="100%" stop-color="#fffbff" />
    </linearGradient>
  </defs>

  <path d="M5 8.5
           C7.3 11 9.7 13.3 12 15.5
           C14.3 13.3 16.7 11 19 8.5" />
</svg>
